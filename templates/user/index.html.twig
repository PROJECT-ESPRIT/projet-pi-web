<form method="get" class="bo-filter-bar">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
            <label><i class="fas fa-search me-1"></i>Recherche</label>
            <input type="text" name="q" value="{{ q }}" class="form-control" placeholder="Email, nom, prénom, rôle…">
        </div>
        <div class="col-6 col-md-2">
            <label><i class="fas fa-sort me-1"></i>Trier par</label>
            <select name="sort" class="form-select">
                <option value="id" {{ sort == 'id' ? 'selected' }}>ID</option>
                <option value="nom" {{ sort == 'nom' ? 'selected' }}>Nom</option>
                <option value="prenom" {{ sort == 'prenom' ? 'selected' }}>Prénom</option>
                <option value="email" {{ sort == 'email' ? 'selected' }}>Email</option>
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label><i class="fas fa-arrows-alt-v me-1"></i>Ordre</label>
            <select name="dir" class="form-select">
                <option value="asc" {{ dir == 'asc' ? 'selected' }}>Croissant</option>
                <option value="desc" {{ dir == 'desc' ? 'selected' }}>Décroissant</option>
            </select>
        </div>
        <div class="col-12 col-md-4 d-flex gap-2">
            <input type="hidden" name="page" value="1">
            <button type="submit" class="btn btn-primary flex-grow-1">
                <span class="btn-label"><i class="fas fa-search me-1"></i> Filtrer</span>
                <span class="btn-spinner" style="display:none;" aria-hidden="true"><i class="fas fa-spinner fa-spin me-1"></i></span>
            </button>
            <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary"><i class="fas fa-undo me-1"></i>Reset</a>
        </div>
    </div>
</form>

<div class="bo-table-card">
    {% if users is not empty %}
        <div class="table-responsive">
            <table class="table bo-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Utilisateur</th>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th>Statut</th>
                        <th>Segment IA</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td class="text-muted" style="font-size:.78rem;">{{ user.id }}</td>
                        <td>
                            <div style="display:flex; align-items:center; gap:.55rem;">
                                <span style="width:32px; height:32px; border-radius:10px; background:linear-gradient(135deg,var(--ac-deep),var(--ac-blue)); color:#fff; display:inline-flex; align-items:center; justify-content:center; font-size:.68rem; font-weight:700; flex-shrink:0;">{{ user.prenom|first|upper }}{{ user.nom|first|upper }}</span>
                                <div>
                                    <div class="fw-semibold" style="color:var(--ac-deep); font-size:.88rem;">{{ user.prenom }} {{ user.nom }}</div>
                                    {% if user.telephone %}
                                        <small class="text-muted" style="font-size:.72rem;">{{ user.telephone }}</small>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td style="font-size:.84rem;">{{ user.email }}</td>
                        <td>
                            {% for role in user.roles %}
                                {% if role != 'ROLE_USER' %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% elseif role == 'ROLE_ARTISTE' %}
                                        <span class="badge bg-info">Artiste</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ role|replace({'ROLE_': ''}) }}</span>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </td>
                        <td>
                            {% if user.status == 'APPROVED' %}
                                <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Approuvé</span>
                            {% elseif user.status == 'EMAIL_PENDING' %}
                                <span class="badge bg-secondary"><i class="fas fa-envelope me-1"></i>Email non vérifié</span>
                            {% elseif user.status == 'EMAIL_VERIFIED' %}
                                <span class="badge bg-warning"><i class="fas fa-clock me-1"></i>En attente admin</span>
                            {% elseif user.status == 'REJECTED' %}
                                <span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Refusé</span>
                            {% elseif user.status == 'SUSPENDED' %}
                                <span class="badge bg-dark"><i class="fas fa-ban me-1"></i>Suspendu</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.segment == 'VIP' %}
                                <span class="badge bg-warning text-dark"><i class="fas fa-crown me-1"></i>VIP</span>
                            {% elseif user.segment == 'ACTIF' %}
                                <span class="badge bg-success"><i class="fas fa-bolt me-1"></i>Actif</span>
                            {% elseif user.segment == 'CHURN_RISK' %}
                                <span class="badge bg-warning"><i class="fas fa-exclamation-triangle me-1"></i>Risque</span>
                            {% elseif user.segment == 'DORMANT' %}
                                <span class="badge bg-secondary"><i class="fas fa-bed me-1"></i>Dormant</span>
                            {% else %}
                                <span class="text-muted fst-italic" style="font-size: 0.8rem;">Non calculé</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-1 justify-content-end">
                                <a href="{{ path('app_user_show', {id: user.id}) }}" class="btn-action btn-view" title="Voir"><i class="fas fa-eye"></i></a>
                                <a href="{{ path('app_user_edit', {id: user.id}) }}" class="btn-action btn-edit" title="Éditer"><i class="fas fa-pen"></i></a>
                                {% if user.status in ['EMAIL_VERIFIED', 'REJECTED', 'SUSPENDED'] %}
                                    <form method="post" action="{{ path('app_user_approve', {id: user.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ user.id) }}">
                                        <button class="btn-action btn-ok" title="Approuver"><i class="fas fa-check"></i></button>
                                    </form>
                                {% endif %}
                                {% if user.status == 'EMAIL_VERIFIED' %}
                                    <form method="post" action="{{ path('app_user_reject', {id: user.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ user.id) }}">
                                        <button class="btn-action btn-del" title="Refuser"><i class="fas fa-times"></i></button>
                                    </form>
                                {% endif %}
                                {% if user.status == 'APPROVED' %}
                                    <form method="post" action="{{ path('app_user_suspend', {id: user.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('suspend' ~ user.id) }}">
                                        <button class="btn-action" title="Suspendre" style="background:rgba(107,114,128,.08); color:#6b7280; width:32px; height:32px; border-radius:10px; border:none; display:inline-flex; align-items:center; justify-content:center; transition:all .2s;" onmouseover="this.style.background='linear-gradient(135deg,#4b5563,#6b7280)';this.style.color='#fff'" onmouseout="this.style.background='rgba(107,114,128,.08)';this.style.color='#6b7280'"><i class="fas fa-ban"></i></button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {% if total_pages > 1 %}
            <div class="bo-pagination">
                <div class="page-info">Page {{ page }} sur {{ total_pages }}</div>
                <nav>
                    <ul class="pagination">
                        <li class="page-item {{ page == 1 ? 'disabled' }}">
                            <a class="page-link" href="{{ path('app_user_index', {q:q, sort:sort, dir:dir, page: page - 1}) }}"><i class="fas fa-chevron-left"></i></a>
                        </li>
                        {% for p in 1..total_pages %}
                            <li class="page-item {{ p == page ? 'active' }}">
                                <a class="page-link" href="{{ path('app_user_index', {q:q, sort:sort, dir:dir, page: p}) }}">{{ p }}</a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ page == total_pages ? 'disabled' }}">
                            <a class="page-link" href="{{ path('app_user_index', {q:q, sort:sort, dir:dir, page: page + 1}) }}"><i class="fas fa-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            </div>
        {% endif %}
    {% else %}
        <div class="bo-empty">
            <i class="fas fa-user-slash"></i>
            <p>Aucun utilisateur trouvé</p>
        </div>
    {% endif %}
</div>
