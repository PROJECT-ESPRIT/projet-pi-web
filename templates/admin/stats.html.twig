        </div>
    </div>

    <div id="hot-events-body">
        <div style="display:flex;align-items:center;gap:.6rem;color:#aaa;font-size:.82rem;padding:.5rem 0;">
            <div style="width:18px;height:18px;border:2px solid #e0daf5;border-top-color:#1E0F75;border-radius:50%;animation:hotSpin .7s linear infinite;flex-shrink:0;"></div>
            Analyse ML en cours…
        </div>
    </div>
</div>

<script>
(function(){
    var body    = document.getElementById('hot-events-body');
    var updated = document.getElementById('hot-events-updated');
    var modePill = document.getElementById('aiModePill');

    var LABELS = {
        fill_rate:       'Taux de remplissage',
        recent_bookings: 'Réservations récentes',
        urgency:         'Urgence (proximité)',
        price_signal:    'Signal prix',
        capacity:        'Capacité',
    };
    var COLORS = {
        fill_rate:'#3785D8', recent_bookings:'#d97706',
        urgency:'#ef4444',   price_signal:'#059669', capacity:'#7c3aed',
    };

    function pillClass(l){ return l==='En feu'?'hot-pill-fire':l==='Populaire'?'hot-pill-pop':l==='Tiede'?'hot-pill-warm':'hot-pill-cold'; }
    function pillIcon(l) { return l==='En feu'?'🔥':l==='Populaire'?'⭐':l==='Tiede'?'🌡️':'❄️'; }
    function barColor(p) { return p>=75?'linear-gradient(90deg,#f97316,#ef4444)':p>=50?'linear-gradient(90deg,#3785D8,#1C1DAB)':p>=25?'linear-gradient(90deg,#a78bfa,#7c3aed)':'linear-gradient(90deg,#d1d5db,#9ca3af)'; }
    function pctColor(p) { return p>=75?'#ef4444':p>=50?'#3785D8':p>=25?'#7c3aed':'#9ca3af'; }
    function rankBg(i)   { return i===0?'linear-gradient(135deg,#d97706,#fbbf24)':i===1?'linear-gradient(135deg,#6b7280,#9ca3af)':i===2?'linear-gradient(135deg,#b45309,#d97706)':'linear-gradient(135deg,#c7cef5,#a5b4fc)'; }
    function fmtDate(iso){ if(!iso) return ''; var d=new Date(iso); return d.toLocaleDateString('fr-FR',{day:'2-digit',month:'short',year:'numeric'}); }
    function fmtTime(iso){ if(!iso) return ''; var d=new Date(iso); return d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}); }

    function renderModal(data) {
        var imp  = (data.ml_info && data.ml_info.feature_importances) || {};
        var desc = document.getElementById('aiModalDesc');
        var cont = document.getElementById('aiModalImportances');
        var note = document.getElementById('aiModalNote');

        if(data.ml_mode) {
            var n = data.ml_info.training_samples || 0;
            desc.innerHTML = 'Le modèle <strong>Random Forest</strong> a analysé <strong>'+n+' événements passés</strong> '
                +'et a appris automatiquement l\'importance de chaque facteur pour prédire quels événements se remplissent le mieux.';
            note.innerHTML = '<i class="fas fa-lightbulb" style="color:#d97706;margin-right:.3rem;"></i>'
                +'Contrairement à une formule fixe, ce modèle <strong>apprend depuis vos données réelles</strong>. '
                +'Plus vous avez d\'événements passés, plus les prédictions seront précises.';
        } else {
            desc.innerHTML = 'Pas assez d\'événements passés pour entraîner le modèle ML (minimum 10). '
                +'Le score est calculé avec la <strong>formule de base</strong> jusqu\'à ce que plus de données soient disponibles.';
            note.innerHTML = '<i class="fas fa-info-circle" style="color:#3785D8;margin-right:.3rem;"></i>'
                +'Le modèle ML s\'activera automatiquement dès que 10 événements passés seront enregistrés dans la base.';
        }

        var keys = Object.keys(imp);
        if(keys.length === 0){ cont.innerHTML=''; return; }
        var total = keys.reduce(function(s,k){ return s+(imp[k]||0); }, 0) || 1;
        var html = '<div style="margin-bottom:.5rem;font-size:.68rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;">Importance des facteurs</div>';
        keys.sort(function(a,b){ return (imp[b]||0)-(imp[a]||0); }).forEach(function(k){
            var pct = Math.round((imp[k]||0)*100);
            var color = COLORS[k] || '#9ca3af';
            var label = LABELS[k] || k;
            html += '<div class="ai-imp-row">'
                +'<div class="ai-imp-label">'+label+'</div>'
                +'<div class="ai-imp-bar-wrap"><div class="ai-imp-bar-fill" style="width:'+pct+'%;background:'+color+';"></div></div>'
                +'<div class="ai-imp-pct" style="color:'+color+';">'+pct+'%</div>'
                +'</div>';
        });
        cont.innerHTML = html;
    }

    fetch('{{ path('ai_events_hotness') }}')
        .then(function(r){ return r.json(); })
        .then(function(data){
            if(!data.success) {
                modePill.className = 'ai-mode-pill ai-mode-fb';
                modePill.innerHTML = '<i class="fas fa-times-circle"></i> Erreur';
                body.innerHTML='<div style="color:#c0392b;font-size:.82rem;padding:.5rem 0;">'
                    +'<i class="fas fa-exclamation-circle" style="margin-right:.3rem;"></i>'
                    +'Erreur IA : ' + (data.error || 'inconnue') + '</div>';
                return;
            }

            // Update mode pill
            if(data.ml_mode) {
                modePill.className = 'ai-mode-pill ai-mode-ml';
                modePill.innerHTML = '<i class="fas fa-check-circle"></i> ML Actif';
            } else {
                modePill.className = 'ai-mode-pill ai-mode-fb';
                modePill.innerHTML = '<i class="fas fa-exclamation-circle"></i> Formule de base';
            }

            updated.innerHTML = '<i class="far fa-clock"></i> ' + new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
            renderModal(data);

            if(!data.hot_events || data.hot_events.length===0){
                body.innerHTML='<div style="text-align:center;color:#aaa;font-size:.82rem;padding:2rem 0;">'
                    +'<i class="fas fa-calendar-times" style="font-size:2rem;opacity:.2;display:block;margin-bottom:.5rem;"></i>'
                    +'Aucun événement à venir.</div>';
                return;
            }

            var events = data.hot_events.slice(0,5);
            var html = '<div class="hot-grid">';
            events.forEach(function(ev, i){
                var hotPct  = Math.round(ev.hotness * 100);
                var fillPct = Math.round(ev.fill_rate * 100);
                var pClass  = pillClass(ev.label);
                var bColor  = barColor(hotPct);
                var pColor  = pctColor(hotPct);
                var delay   = (i * 0.07).toFixed(2);
                var free    = ev.nb_places - ev.reservations_total;

                html += '<div class="hot-card" style="animation-delay:'+delay+'s;">'
                    +'<div class="hot-card-rank" style="background:'+rankBg(i)+';">'+(i+1)+'</div>'
                    +'<div class="hot-card-name">'+ev.titre+'</div>'
                    +'<div class="hot-card-meta">'
                        +'<span><i class="fas fa-map-marker-alt"></i> '+ev.lieu+'</span>'
                        +'<span><i class="far fa-calendar"></i> '+fmtDate(ev.date_debut)+'</span>'
                        +'<span><i class="far fa-clock"></i> '+fmtTime(ev.date_debut)+'</span>'
                    +'</div>'
                    +'<div><span class="hot-pill '+pClass+'">'+pillIcon(ev.label)+' '+ev.label+'</span></div>'
                    +'<div class="hot-score-row">'
                        +'<span class="hot-score-lbl"><i class="fas fa-thermometer-half" style="margin-right:.2rem;"></i>Score IA</span>'
                        +'<span class="hot-score-val" style="color:'+pColor+';">'+hotPct+'%</span>'
                    +'</div>'
                    +'<div class="hot-bar-wrap"><div class="hot-bar-fill" style="width:'+hotPct+'%;background:'+bColor+';"></div></div>'
                    +'<div class="hot-score-row" style="margin-bottom:.2rem;">'
                        +'<span class="hot-score-lbl"><i class="fas fa-users" style="color:#3785D8;margin-right:.2rem;"></i>Remplissage</span>'
                        +'<span style="font-size:.72rem;font-weight:700;color:#3785D8;">'+fillPct+'%</span>'
                    +'</div>'
                    +'<div class="hot-bar-wrap" style="height:4px;margin-bottom:.55rem;"><div class="hot-bar-fill" style="width:'+fillPct+'%;background:linear-gradient(90deg,#3785D8,#1C1DAB);"></div></div>'
                    +'<div class="hot-card-foot">'
                        +'<span class="hot-card-seats"><i class="fas fa-chair"></i> '+free+' places libres</span>'
                        +'<span class="hot-card-days" style="color:'+(ev.days_until<=7?'#ef4444':ev.days_until<=30?'#d97706':'#6b7280')+';">'
                            +'<i class="fas fa-hourglass-half"></i> J-'+ev.days_until
                        +'</span>'
                    +'</div>'
                +'</div>';
            });
            html += '</div>';
            body.innerHTML = html;
        })
        .catch(function(){
            modePill.className = 'ai-mode-pill ai-mode-fb';
            modePill.innerHTML = '<i class="fas fa-times-circle"></i> Erreur';
            body.innerHTML='<div style="color:#c0392b;font-size:.82rem;padding:.5rem 0;">'
                +'<i class="fas fa-exclamation-circle" style="margin-right:.3rem;"></i>'
                +'Impossible de charger les données IA.</div>';
        });
})();
</script>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    Chart.defaults.font.family = "'Manrope', sans-serif";
    Chart.defaults.font.size = 11;

    var C = {
        deep:'#1E0F75', mid:'#1C1DAB', blue:'#3785D8', lavender:'#BF8CE1',
        sky:'#ADC6E5', pink:'#EBB2C3', green:'#059669', greenLight:'#34d399',
        red:'#dc2626', redLight:'#f87171', amber:'#d97706', amberLight:'#fbbf24',
        gray:'#9ca3af', purple:'#7c3aed'
    };

    function makeGradient(ctx, c1, c2) {
        var g = ctx.createLinearGradient(0, 0, 0, ctx.canvas.height);
        g.addColorStop(0, c1); g.addColorStop(1, c2);
        return g;
    }

    var commonBar = { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
        scales:{y:{beginAtZero:true,ticks:{stepSize:1},grid:{color:'#f3f4f6',drawBorder:false}},x:{grid:{display:false}}} };
    var commonLine = { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
        scales:{y:{beginAtZero:true,ticks:{stepSize:1},grid:{color:'#f3f4f6',drawBorder:false}},x:{grid:{display:false}}} };
    var commonDoughnut = { responsive:true, maintainAspectRatio:false, cutout:'65%', plugins:{legend:{display:false}} };

    // Reservations
    var resCtx = document.getElementById('monthlyResChart').getContext('2d');
    var resGrad = makeGradient(resCtx, C.blue+'99', C.blue+'33');
    new Chart(resCtx, {
        type:'bar',
        data:{ labels:{{ monthlyReservations|map(m => m.month)|json_encode|raw }},
            datasets:[{ data:{{ monthlyReservations|map(m => m.count)|json_encode|raw }},
                backgroundColor:resGrad, borderColor:C.blue, borderWidth:1.5, borderRadius:6, barPercentage:.6 }] },
        options:commonBar
    });

    // Registrations
    var regCtx = document.getElementById('monthlyRegChart').getContext('2d');
    var regGrad = makeGradient(regCtx, C.lavender+'44', C.lavender+'05');
    var regLabels = {{ monthlyRegistrations|map(m => m.month)|json_encode|raw }};
    var regValues = {{ monthlyRegistrations|map(m => m.count)|json_encode|raw }};
    var nextRegLabel = {{ nextMonthRegistrationPrediction.nextMonthLabel|json_encode|raw }};
    var regPredicted = {{ nextMonthRegistrationPrediction.predictedCount|json_encode|raw }};
    var regLower = {{ nextMonthRegistrationPrediction.lowerBound|json_encode|raw }};
    var regUpper = {{ nextMonthRegistrationPrediction.upperBound|json_encode|raw }};
    var lastActual = regValues.length > 0 ? regValues[regValues.length - 1] : null;

    regLabels = regLabels.concat([nextRegLabel]);
    var actualSeries = regValues.concat([null]);
    var forecastSeries = new Array(regLabels.length).fill(null);
    var lowerBandSeries = new Array(regLabels.length).fill(null);
    var upperBandSeries = new Array(regLabels.length).fill(null);
    if (regValues.length > 0) {
        forecastSeries[regLabels.length - 2] = lastActual;
        forecastSeries[regLabels.length - 1] = regPredicted;
        lowerBandSeries[regLabels.length - 1] = regLower;
        upperBandSeries[regLabels.length - 1] = regUpper;
    }

    new Chart(regCtx, {
        type:'line',
        data:{ labels:regLabels,
            datasets:[
            { data:actualSeries,
                borderColor:C.lavender, backgroundColor:regGrad, borderWidth:2.5,
                fill:true, tension:.4, pointBackgroundColor:'#fff', pointBorderColor:C.lavender,
                pointBorderWidth:2, pointRadius:4, pointHoverRadius:6 },
            { data:forecastSeries,
                borderColor:C.deep, borderDash:[6,4], borderWidth:2,
                fill:false, tension:.35, pointBackgroundColor:C.deep, pointBorderColor:'#fff',
                pointBorderWidth:1.5, pointRadius:3, pointHoverRadius:5 },
            { data:upperBandSeries, borderColor:'#9ca3af', borderDash:[2,4], borderWidth:1.5, fill:false, pointRadius:0 },
            { data:lowerBandSeries, borderColor:'#9ca3af', borderDash:[2,4], borderWidth:1.5, fill:false, pointRadius:0 }
            ] },
        options:commonLine
    });

    // Revenue
    var revCtx = document.getElementById('monthlyRevChart').getContext('2d');
    var revGrad = makeGradient(revCtx, C.green+'88', C.greenLight+'22');
    new Chart(revCtx, {
        type:'bar',
        data:{ labels:{{ monthlyRevenue|map(m => m.month)|json_encode|raw }},
            datasets:[{ data:{{ monthlyRevenue|map(m => m.total)|json_encode|raw }},
                backgroundColor:revGrad, borderColor:C.green, borderWidth:1.5, borderRadius:6, barPercentage:.6 }] },
        options:{ responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
            scales:{y:{beginAtZero:true,grid:{color:'#f3f4f6',drawBorder:false}},x:{grid:{display:false}}} }
    });

    // Order status
    new Chart(document.getElementById('orderStatusChart'), {
        type:'doughnut',
        data:{ labels:{{ ordersByStatus|map(o => o.status)|json_encode|raw }},
            datasets:[{ data:{{ ordersByStatus|map(o => o.count)|json_encode|raw }},
                backgroundColor:[C.amber, C.green, C.red, C.blue, C.gray],
                borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
        options:commonDoughnut
    });

    // Donations by type
    {% if donationsByType|length > 0 %}
    new Chart(document.getElementById('donTypeChart'), {
        type:'doughnut',
        data:{ labels:{{ donationsByType|map(d => d.typeName ?? 'Autre')|json_encode|raw }},
            datasets:[{ data:{{ donationsByType|map(d => d.count)|json_encode|raw }},
                backgroundColor:[C.lavender, C.blue, C.pink, C.green, C.amber, C.sky],
                borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
        options:commonDoughnut
    });
    {% endif %}

    // Users by role
    new Chart(document.getElementById('usersRoleChart'), {
        type:'doughnut',
        data:{ labels:{{ usersByRole|map(u => u.role|replace({'ROLE_': ''})|title)|json_encode|raw }},
            datasets:[{ data:{{ usersByRole|map(u => u.count)|json_encode|raw }},
                backgroundColor:[C.red, C.blue, C.green, C.amber],
                borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
        options:commonDoughnut
    });

    // Reservations by status
    new Chart(document.getElementById('resStatusChart'), {
        type:'doughnut',
        data:{ labels:{{ reservationsByStatus|map(r => r.status)|json_encode|raw }},
            datasets:[{ data:{{ reservationsByStatus|map(r => r.count)|json_encode|raw }},
                backgroundColor:[C.green, C.amber, C.red, C.gray],
                borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
        options:commonDoughnut
    });

    // Monthly events
    var evCtx = document.getElementById('monthlyEvChart').getContext('2d');
    var evGrad = makeGradient(evCtx, C.lavender+'88', C.lavender+'22');
    new Chart(evCtx, {
        type:'bar',
        data:{ labels:{{ monthlyEvents|map(m => m.month)|json_encode|raw }},
            datasets:[{ data:{{ monthlyEvents|map(m => m.count)|json_encode|raw }},
                backgroundColor:evGrad, borderColor:C.lavender, borderWidth:1.5, borderRadius:6, barPercentage:.6 }] },
        options:commonBar
    });

    // Forum
    var fCtx = document.getElementById('forumChart').getContext('2d');
    var fGrad = makeGradient(fCtx, C.amber+'44', C.amberLight+'08');
    new Chart(fCtx, {
        type:'line',
        data:{ labels:{{ monthlyForumPosts|map(m => m.month)|json_encode|raw }},
            datasets:[{ label:'Sujets', data:{{ monthlyForumPosts|map(m => m.count)|json_encode|raw }},
                borderColor:C.amber, backgroundColor:fGrad, borderWidth:2.5, fill:true, tension:.4,
                pointBackgroundColor:'#fff', pointBorderColor:C.amber, pointBorderWidth:2, pointRadius:4 }] },
        options:commonLine
    });

    // Monthly donations
    var dCtx = document.getElementById('monthlyDonChart').getContext('2d');
    var dGrad = makeGradient(dCtx, C.pink+'44', C.pink+'08');
    new Chart(dCtx, {
        type:'line',
        data:{ labels:{{ monthlyDonations|map(m => m.month)|json_encode|raw }},
            datasets:[{ data:{{ monthlyDonations|map(m => m.count)|json_encode|raw }},
                borderColor:'#db2777', backgroundColor:dGrad, borderWidth:2.5, fill:true, tension:.4,
                pointBackgroundColor:'#fff', pointBorderColor:'#db2777', pointBorderWidth:2, pointRadius:4 }] },
        options:commonLine
    });
});
</script>
{% endblock %}
