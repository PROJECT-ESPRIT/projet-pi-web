{% extends 'base.html.twig' %}

{% block title %}{{ forum.titre }}{% endblock %}

{% block body %}
<div class="bo-page-header">
    <h1>
        <i class="fas fa-comment-dots"></i> {{ forum.titre }}
    </h1>
    <div class="bo-actions">
        <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Retour</a>
        {% if app.user %}
            <a href="{{ path('app_forum_edit', {'id': forum.id}) }}" class="btn btn-outline-secondary"><i class="fas fa-edit me-1"></i>Editer</a>
        {% endif %}
    </div>
</div>

<div class="bo-table-card p-4 mb-3">
    <div class="d-flex justify-content-between text-muted small mb-3">
        <span><i class="fas fa-user"></i> {{ forum.auteur ?: 'Anonyme' }}</span>
        <span><i class="far fa-clock"></i> {{ forum.dateCreation|date('d/m/Y H:i') }}</span>
    </div>
    <div class="forum-message" style="white-space: pre-wrap">{{ forum.message }}</div>
</div>

{% if forum.reponses is defined and forum.reponses|length > 0 %}
    <h3 class="h5 mt-4"><i class="fas fa-reply"></i> Réponses ({{ forum.reponses|length }})</h3>
    {% for r in forum.reponses %}
        <div class="bo-table-card p-3 mb-2">
            <div class="d-flex justify-content-between text-muted small mb-2">
                <span><i class="fas fa-user"></i> {{ r.auteur ? (r.auteur.prenom ~ ' ' ~ r.auteur.nom) : 'Anonyme' }}</span>
                <span><i class="far fa-clock"></i> {{ r.dateReponse|date('d/m/Y H:i') }}</span>
            </div>
            <div style="white-space: pre-wrap">{{ r.contenu }}</div>
        </div>
    {% endfor %}
{% endif %}

{% if app.user %}
    <a href="{{ path('app_forum_reponse_new') }}?forum={{ forum.id }}" class="btn btn-primary"><i class="fas fa-reply me-1"></i>Répondre</a>
    {{ include('forum/_delete_form.html.twig') }}
{% endif %}
{% endblock %}
