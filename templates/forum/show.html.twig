{% extends 'base.html.twig' %}

{% block title %}{{ forum.sujet }} - Forum{% endblock %}

{% block body %}
<div class="public-shell">
    {% for type, messages in app.session.flashbag.all() %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show mb-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    
    <div class="row">
        <div class="col-12">
            <!-- Post principal -->
            <article class="feature-card feature-card--forum facebook-post mb-4">
                <!-- Header : Auteur et date en haut à gauche -->
                <header class="post-header">
                    <div class="post-author-info">
                        <div class="author-avatar">
                            <div class="avatar-placeholder">
                                {{ forum.nom|first }}{{ forum.prenom|first }}
                            </div>
                        </div>
                        <div class="author-details">
                            <div class="author-name">{{ forum.nom }} {{ forum.prenom }}</div>
                            <div class="post-date">{{ forum.dateCreation ? forum.dateCreation|date('d/m/Y') : '' }}</div>
                        </div>
                    </div>
                    {% if is_granted('ROLE_ADMIN') or (app.user and app.user.email == forum.email) %}
                        <div class="post-actions" style="display: flex; gap: 0.5rem; align-items: center;">
                            <div class="dropdown-container">
                                <a href="{{ path('app_forum_edit', {'id': forum.id}) }}" 
                                   style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: #3785D8; color: white; text-decoration: none; border-radius: 6px; font-size: 0.875rem; font-weight: 600; transition: all 0.3s;"
                                   onmouseover="this.style.background='#1C1DAB'; this.style.transform='translateY(-2px)';"
                                   onmouseout="this.style.background='#3785D8'; this.style.transform='translateY(0)';">
                                    <i class="fas fa-edit"></i>
                                    Modifier
                                </a>
                                <form method="post" action="{{ path('app_forum_delete', {'id': forum.id}) }}" 
                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce post ?');" 
                                      style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ forum.id) }}">
                                    <button type="submit" 
                                            style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: #dc3545; color: white; border: none; border-radius: 6px; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: all 0.3s;"
                                            onmouseover="this.style.background='#c82333'; this.style.transform='translateY(-2px)';"
                                            onmouseout="this.style.background='#dc3545'; this.style.transform='translateY(0)';">
                                        <i class="fas fa-trash"></i>
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                </header>
                
                <!-- Corps : Contenu du post -->
                <div class="post-body">
                    <h2 class="post-title">{{ forum.sujet }}</h2>
                    <div class="post-content">{{ forum.message|nl2br }}</div>
                </div>
                
                <!-- Actions : Barre horizontale avec 3 boutons -->
                <div class="post-actions-bar">
                    <button class="action-btn like-btn {% if app.user and (forum.likes|filter(like => like.user == app.user)|length > 0) %}liked{% endif %}" 
                            data-forum-id="{{ forum.id }}"
                            data-liked="{{ app.user ? (forum.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                        <i class="{% if app.user and (forum.likes|filter(like => like.user == app.user)|length > 0) %}fas{% else %}far{% endif %} fa-heart"></i>
                        <span>Like</span>
                        <span class="count">{{ forum.getLikesCount() }}</span>
                    </button>
                    <button class="action-btn comment-btn" onclick="scrollToComments()">
                        <i class="far fa-comment"></i>
                        <span>Commenter</span>
                        <span class="count">{{ forum.reponses|length }}</span>
                    </button>
                    <button class="action-btn report-btn {% if app.user and (forum.signalements|filter(report => report.user == app.user)|length > 0) %}reported{% endif %}" 
                            data-forum-id="{{ forum.id }}"
                            data-reported="{{ app.user ? (forum.signalements|filter(report => report.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                        <i class="{% if app.user and (forum.signalements|filter(report => report.user == app.user)|length > 0) %}fas{% else %}far{% endif %} fa-flag"></i>
                        <span>Signaler</span>
                    </button>
                    <a href="{{ path('app_forum_save_pdf', {'id': forum.id}) }}" 
                       class="action-btn pdf-btn" 
                       target="_blank">
                        <i class="fas fa-file-pdf"></i>
                        <span>PDF</span>
                    </a>
                </div>
            </article>

            <!-- Section des réponses -->
            <div class="post-responses" id="comments-section">
                <div class="responses-header">
                    <h5>
                        <i class="far fa-comments"></i> 
                        {{ forum.reponses|length }} réponse{{ forum.reponses|length > 1 ? 's' : '' }}
                    </h5>
                </div>
                
                <!-- Formulaire d'ajout de réponse -->
                {% if app.user %}
                    <div class="comment-form-container">
                        <h6>Ajouter une réponse</h6>
                        <form action="{{ path('app_forum_reponse_create') }}" method="POST" class="comment-form" enctype="multipart/form-data">
                            <input type="hidden" name="forum_id" value="{{ forum.id }}">
                            <textarea name="contenu" placeholder="Écrivez votre réponse..." required></textarea>
                            
                            <!-- Voice Recording Section -->
                            <div class="voice-recording-section">
                                <div class="voice-controls">
                                    <button type="button" class="voice-record-btn" id="voiceRecordBtn">
                                        <i class="fas fa-microphone"></i>
                                        <span>Enregistrer un message vocal</span>
                                    </button>
                                    <button type="button" class="voice-stop-btn" id="voiceStopBtn" style="display: none;">
                                        <i class="fas fa-stop"></i>
                                        <span>Arrêter</span>
                                    </button>
                                    <button type="button" class="voice-play-btn" id="voicePlayBtn" style="display: none;">
                                        <i class="fas fa-play"></i>
                                        <span>Écouter</span>
                                    </button>
                                    <button type="button" class="voice-delete-btn" id="voiceDeleteBtn" style="display: none;">
                                        <i class="fas fa-trash"></i>
                                        <span>Supprimer</span>
                                    </button>
                                </div>
                                <div class="voice-status" id="voiceStatus"></div>
                                <audio id="voicePreview" controls style="display: none;"></audio>
                                <input type="file" name="voice_message" id="voiceFileInput" accept="audio/*" style="display: none;">
                                <input type="hidden" name="voice_data" id="voiceDataInput">
                            </div>
                            
                            <button type="submit" class="submit-comment-btn">
                                <i class="fas fa-paper-plane"></i> Publier
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="login-prompt">
                        <a href="{{ path('app_login') }}">Connectez-vous</a> pour pouvoir répondre.
                    </div>
                {% endif %}

                <!-- Liste des réponses avec indentation -->
                {% if forum.reponses|length > 0 %}
                    <div class="responses-list">
                        {% for reponse in forum.reponses %}
                            <div class="response-item" data-reponse-id="{{ reponse.id }}">
                                <div class="response-header">
                                    <div class="response-avatar">
                                        {{ reponse.auteur.prenom|first }}{{ reponse.auteur.nom|first }}
                                    </div>
                                    <div class="response-info">
                                        <div class="response-author">{{ reponse.auteur.nom }} {{ reponse.auteur.prenom }}</div>
                                        <div class="response-date">{{ reponse.dateReponse ? reponse.dateReponse|date('d/m/Y') : '' }}</div>
                                    </div>
                                    {% if is_granted('ROLE_ADMIN') or (app.user and app.user == reponse.auteur) %}
                                        <div class="response-actions-menu" style="display: flex; gap: 0.5rem; align-items: center;">
                                            <div class="dropdown-container">
                                                {% if app.user and app.user == reponse.auteur %}
                                                    <a href="{{ path('app_forum_reponse_edit', {'id': reponse.id}) }}" 
                                                       style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.8rem; background: #3785D8; color: white; text-decoration: none; border-radius: 6px; font-size: 0.8rem; font-weight: 600; transition: all 0.3s;"
                                                       onmouseover="this.style.background='#1C1DAB'; this.style.transform='translateY(-2px)';"
                                                       onmouseout="this.style.background='#3785D8'; this.style.transform='translateY(0)';">
                                                        <i class="fas fa-edit"></i>
                                                        Modifier
                                                    </a>
                                                {% endif %}
                                                {% if is_granted('ROLE_ADMIN') or (app.user and app.user == reponse.auteur) %}
                                                    <form method="post" action="{{ path('app_forum_reponse_delete', {'id': reponse.id}) }}" 
                                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce commentaire ?');" 
                                                          style="display: inline;">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reponse.id) }}">
                                                        <button type="submit" 
                                                                style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.8rem; background: #dc3545; color: white; border: none; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.3s;"
                                                                onmouseover="this.style.background='#c82333'; this.style.transform='translateY(-2px)';"
                                                                onmouseout="this.style.background='#dc3545'; this.style.transform='translateY(0)';">
                                                            <i class="fas fa-trash"></i>
                                                            Supprimer
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="response-content">{{ reponse.contenu|nl2br }}</div>
                                {% if reponse.voiceMessage %}
                                    <div class="voice-message-player">
                                        <audio controls preload="none" style="width: 100%; max-width: 300px;">
                                            <source src="{{ asset(reponse.voiceMessage) }}" type="audio/wav">
                                            <source src="{{ asset(reponse.voiceMessage) }}" type="audio/mpeg">
                                            <source src="{{ asset(reponse.voiceMessage) }}" type="audio/ogg">
                                            Votre navigateur ne supporte pas l'élément audio.
                                        </audio>
                                        <div class="voice-message-label">
                                            <i class="fas fa-microphone"></i> Message vocal
                                        </div>
                                    </div>
                                {% endif %}
                                <div class="response-actions">
                                    <button class="response-action-btn response-like-btn {% if app.user and (reponse.likes|filter(like => like.user == app.user)|length > 0) %}liked{% endif %}" 
                                            data-reponse-id="{{ reponse.id }}"
                                            data-liked="{{ app.user ? (reponse.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                                        <i class="{% if app.user and (reponse.likes|filter(like => like.user == app.user)|length > 0) %}fas{% else %}far{% endif %} fa-heart"></i>
                                        <span>{{ reponse.getLikesCount() }}</span>
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-responses">
                        <i class="far fa-comments"></i>
                        <p>Soyez le premier à commenter !</p>
                    </div>
                {% endif %}
            </div>

            <div class="mt-4">
                <a href="{{ path('app_forum_index') }}" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-1"></i> Retour au forum
                </a>
            </div>
        </div>
    </div>
</div>

<style>
.facebook-post {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    border: 1px solid rgba(30, 15, 117, 0.1);
}

/* ===== PAGE CONTAINER ===== */
.public-shell {
    min-height: 100vh;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    padding: 2rem;
    position: relative;
}

.public-shell::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 50%, var(--ac-lavender) 100%);
    opacity: 0.05;
    z-index: -1;
}

/* ===== MAIN POST CARD ===== */
.feature-card.feature-card--forum.facebook-post {
    background: var(--bg-primary);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--border-primary);
    overflow: hidden;
    position: relative;
    backdrop-filter: blur(10px);
    margin-bottom: 2rem;
    transition: var(--transition);
}

.feature-card.feature-card--forum.facebook-post::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    opacity: 0.8;
}

.feature-card.feature-card--forum.facebook-post:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(30,15,117,0.2);
}

/* ===== POST HEADER ===== */
.post-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-secondary);
    position: relative;
}

.post-author {
    display: flex;
    align-items: center;
    gap: 1.25rem;
}

.avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--ac-deep), var(--ac-lavender));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 1.25rem;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
}

.avatar::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(45deg, transparent, rgba(255,255,255,0.2), transparent);
    animation: shine 3s infinite;
}

@keyframes shine {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.author-info strong {
    color: var(--text-primary);
    font-size: 1.125rem;
    font-weight: 700;
    display: block;
    margin-bottom: 0.25rem;
}

.author-info .text-muted {
    color: var(--text-muted);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.author-info .text-muted::before {
    content: '📅';
    font-size: 0.75rem;
}

/* ===== POST ACTIONS ===== */
.post-actions {
    position: relative;
}

.facebook-btn {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

.facebook-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.facebook-btn:hover::before {
    left: 100%;
}

.facebook-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.facebook-btn:active {
    transform: translateY(0);
}

.facebook-btn.liked {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
}

.facebook-btn.liked:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
}

.facebook-btn.reported {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
}

.facebook-btn.reported:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(245, 158, 11, 0.3);
}

.facebook-btn.loading {
    opacity: 0.7;
    pointer-events: none;
}

.facebook-btn.loading::after {
    content: " Génération...";
    margin-left: 0.5rem;
}

/* ===== POST CONTENT ===== */
.post-content {
    padding: 0 2rem 1.5rem;
}

.post-content h2 {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1.3;
    position: relative;
    padding-left: 1rem;
}

.post-content h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 70%;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    border-radius: var(--radius-sm);
}

.post-content p {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    position: relative;
    padding-left: 1rem;
}

.post-content p::before {
    content: '"';
    position: absolute;
    left: -0.5rem;
    top: 0;
    font-size: 3rem;
    color: var(--ac-mid);
    opacity: 0.2;
    font-family: Georgia, serif;
}

/* ===== BARRE D'ACTIONS ===== */
.post-actions-bar {
    display: flex;
    border-top: 1px solid var(--border-secondary);
    border-bottom: 1px solid var(--border-secondary);
    padding: 0;
    background: var(--bg-tertiary);
}

.post-actions-bar .action-btn {
    flex: 1;
    padding: 1rem;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    position: relative;
    text-decoration: none;
}

.post-actions-bar .action-btn:hover {
    background: rgba(30, 15, 117, 0.05);
    color: var(--ac-deep);
}

.post-actions-bar .action-btn.liked {
    color: #ef4444;
}

.post-actions-bar .action-btn.reported {
    color: #f59e0b;
}

.post-actions-bar .action-btn.pdf-btn {
    color: var(--ac-deep);
}

.post-actions-bar .action-btn .count {
    background: rgba(30, 15, 117, 0.1);
    color: var(--ac-deep);
    border-radius: 12px;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 20px;
    text-align: center;
}

.post-actions-bar .action-btn.liked .count {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
}

/* ===== SECTION RÉPONSES ===== */
.post-responses {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    padding: 2rem;
    margin-top: 2rem;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
}

.responses-header h5 {
    color: var(--text-primary);
    font-weight: 700;
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.comment-form-container h6 {
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 1rem;
    font-size: 1rem;
}

.comment-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
}

.comment-form textarea {
    border: 2px solid var(--border-primary);
    border-radius: var(--radius-md);
    padding: 0.75rem;
    font-size: 0.9rem;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    transition: var(--transition);
    resize: vertical;
    min-height: 80px;
    font-family: inherit;
}

.comment-form textarea:focus {
    outline: none;
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55,133,216,0.1);
    background: var(--bg-primary);
}

.submit-comment-btn {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    align-self: flex-end;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.submit-comment-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.login-prompt {
    text-align: center;
    padding: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
}

.login-prompt a {
    color: var(--ac-mid);
    text-decoration: none;
    font-weight: 600;
}

.login-prompt a:hover {
    text-decoration: underline;
}

/* ===== LISTE DES RÉPONSES ===== */
.responses-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.response-item {
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    padding: 1rem;
    border: 1px solid var(--border-primary);
    margin-left: 2rem;
    position: relative;
    transition: var(--transition);
}

.response-item::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 1.5rem;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--ac-mid);
    border-radius: 50%;
}

.response-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
}

.response-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
}

.response-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--ac-sky), var(--ac-mid));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 0.8rem;
    flex-shrink: 0;
}

.response-info {
    flex: 1;
}

.response-author {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
}

.response-date {
    color: var(--text-muted);
    font-size: 0.8rem;
}

.response-content {
    color: var(--text-secondary);
    line-height: 1.5;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
}

.response-actions {
    display: flex;
    gap: 0.5rem;
}

.response-action-btn {
    background: transparent;
    border: 1px solid var(--border-primary);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
