    box-shadow: 0 4px 12px rgba(55, 133, 216, 0.3);
}

/* ===== VOICE MESSAGE PLAYER ===== */
.voice-message-player {
    margin-top: 0.75rem;
    padding: 0.75rem;
    background: rgba(55, 133, 216, 0.05);
    border: 1px solid rgba(55, 133, 216, 0.2);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.voice-message-player audio {
    flex: 1;
    height: 32px;
}

.voice-message-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ac-mid);
    font-weight: 600;
    white-space: nowrap;
}

.voice-message-label i {
    color: var(--ac-deep);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Vérifier si on vient d'une modification (message flash présent)
    const hasFlashMessage = document.querySelector('.alert-success') && document.querySelector('.alert-success').textContent.includes('modifiée');
    
    // Si on vient d'une modification, ouvrir les commentaires
    if (hasFlashMessage) {
        setTimeout(function() {
            scrollToComments();
        }, 500);
    }
    
    // Fonction pour faire défiler jusqu'à la section des commentaires
    window.scrollToComments = function() {
        const commentsSection = document.getElementById('comments-section');
        if (commentsSection) {
            commentsSection.scrollIntoView({ behavior: 'smooth' });
        }
    };

    // Fonction dropdown isolée
    window.testDropdown = function(button) {
        console.log('=== DROPDOWN CLIC ===');
        console.log('Button:', button);
        
        // Trouver le menu
        const menu = button.nextElementSibling;
        console.log('Menu trouvé:', menu);
        
        if (!menu) {
            console.error('Menu NON TROUVÉ!');
            return;
        }
        
        // État actuel
        const isVisible = menu.style.display !== 'none' && menu.style.display !== '';
        console.log('État actuel:', isVisible);
        
        // Fermer tous les autres menus
        document.querySelectorAll('.dropdown-menu').forEach(function(otherMenu) {
            if (otherMenu !== menu) {
                otherMenu.style.display = 'none';
            }
        });
        
        // Basculer ce menu
        menu.style.display = isVisible ? 'none' : 'block';
        console.log('Nouvel état:', menu.style.display);
    };
    
    // Test des éléments
    setTimeout(function() {
        const buttons = document.querySelectorAll('.dropdown-toggle');
        const menus = document.querySelectorAll('.dropdown-menu');
        console.log('Boutons trouvés:', buttons.length);
        console.log('Menus trouvés:', menus.length);
        
        // Ajouter des listeners manuellement
        buttons.forEach(function(button, index) {
            console.log(`Ajout listener sur bouton ${index}:`, button);
            button.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('CLIC DIRECT DÉTECTÉ!');
                window.testDropdown(button);
            });
        });
    }, 500);
    
    // Fermer les menus en cliquant ailleurs
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.dropdown-container')) {
            document.querySelectorAll('.dropdown-menu').forEach(function(menu) {
                menu.style.display = 'none';
            });
        }
    });

    // Voice Recording Functionality
    let mediaRecorder;
    let audioChunks = [];
    let audioBlob;
    let isRecording = false;

    const voiceRecordBtn = document.getElementById('voiceRecordBtn');
    const voiceStopBtn = document.getElementById('voiceStopBtn');
    const voicePlayBtn = document.getElementById('voicePlayBtn');
    const voiceDeleteBtn = document.getElementById('voiceDeleteBtn');
    const voiceStatus = document.getElementById('voiceStatus');
    const voicePreview = document.getElementById('voicePreview');
    const voiceDataInput = document.getElementById('voiceDataInput');

    // Check if browser supports MediaRecorder API
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
        voiceStatus.textContent = "Votre navigateur ne supporte pas l'enregistrement audio";
        voiceRecordBtn.disabled = true;
    }

    voiceRecordBtn.addEventListener('click', startRecording);
    voiceStopBtn.addEventListener('click', stopRecording);
    voicePlayBtn.addEventListener('click', playRecording);
    voiceDeleteBtn.addEventListener('click', deleteRecording);

    async function startRecording() {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorder = new MediaRecorder(stream);
            audioChunks = [];

            mediaRecorder.ondataavailable = (event) => {
                audioChunks.push(event.data);
            };

            mediaRecorder.onstop = () => {
                audioBlob = new Blob(audioChunks, { type: 'audio/wav' });
                const audioUrl = URL.createObjectURL(audioBlob);
                voicePreview.src = audioUrl;
                voicePreview.style.display = 'block';
                voiceDataInput.value = audioUrl;
                
                // Convert blob to base64 for form submission
                const reader = new FileReader();
                reader.onloadend = () => {
                    voiceDataInput.value = reader.result;
                };
                reader.readAsDataURL(audioBlob);
            };

            mediaRecorder.start();
            isRecording = true;
            
            // Update UI
            voiceRecordBtn.style.display = 'none';
            voiceStopBtn.style.display = 'flex';
            voicePlayBtn.style.display = 'none';
            voiceDeleteBtn.style.display = 'none';
            voiceStatus.textContent = 'Enregistrement en cours...';
            voiceRecordBtn.classList.add('recording');

        } catch (error) {
            console.error('Error accessing microphone:', error);
            voiceStatus.textContent = 'Erreur: Impossible d\'accéder au microphone';
        }
    }

    function stopRecording() {
        if (mediaRecorder && isRecording) {
            mediaRecorder.stop();
            mediaRecorder.stream.getTracks().forEach(track => track.stop());
            isRecording = false;
            
            // Update UI
            voiceRecordBtn.style.display = 'flex';
            voiceStopBtn.style.display = 'none';
            voicePlayBtn.style.display = 'flex';
            voiceDeleteBtn.style.display = 'flex';
            voiceStatus.textContent = 'Enregistrement terminé';
            voiceRecordBtn.classList.remove('recording');
        }
    }

    function playRecording() {
        if (voicePreview.src) {
            voicePreview.play();
        }
    }

    function deleteRecording() {
        // Reset everything
        audioChunks = [];
        audioBlob = null;
        voicePreview.src = '';
        voicePreview.style.display = 'none';
        voiceDataInput.value = '';
        
        // Update UI
        voiceRecordBtn.style.display = 'flex';
        voiceStopBtn.style.display = 'none';
        voicePlayBtn.style.display = 'none';
        voiceDeleteBtn.style.display = 'none';
        voiceStatus.textContent = '';
        voiceRecordBtn.classList.remove('recording');
    }

    // Form submission validation
    const commentForm = document.querySelector('.comment-form');
    if (commentForm) {
        commentForm.addEventListener('submit', function(e) {
            const textarea = this.querySelector('textarea[name="contenu"]');
            const voiceData = voiceDataInput.value;
            
            // Check if either text or voice is provided
            if (!textarea.value.trim() && !voiceData) {
                e.preventDefault();
                voiceStatus.textContent = 'Veuillez écrire un message ou enregistrer un message vocal';
                voiceStatus.style.color = '#ef4444';
            }
        });
    }
});
</script>
{% endblock %}
