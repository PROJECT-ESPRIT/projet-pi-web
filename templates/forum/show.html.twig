{% extends 'base.html.twig' %}

{% block title %}{{ forum.sujet }} - Forum{% endblock %}

{% block body %}
<div class="public-shell">
    {% for type, messages in app.session.flashbag.all() %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show mb-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    
    <div class="row">
        <div class="col-12">
            <!-- Post principal -->
            <div class="feature-card feature-card--forum facebook-post mb-4">
                <!-- En-tête du post -->
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex align-items-center">
                        <div class="avatar me-2" style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(145deg, var(--ac-deep), var(--ac-lavender)); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                            {{ forum.nom|first }}{{ forum.prenom|first }}
                        </div>
                        <div>
                            <strong style="color: var(--ac-deep); font-size: 0.9rem;">{{ forum.nom }} {{ forum.prenom }}</strong>
                            <div class="text-muted" style="font-size: 0.8rem;">
                                <i class="fas fa-clock me-1"></i>{{ forum.dateCreation ? forum.dateCreation|date('d M \à H:i') : '' }}
                            </div>
                        </div>
                    </div>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="dropdown">
                            <button class="facebook-btn btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="fas fa-ellipsis-h"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_forum_edit', {'id': forum.id}) }}">
                                    <i class="fas fa-edit me-1"></i> Modifier
                                </a></li>
                                <li>
                                    {{ include('forum/_delete_form.html.twig') }}
                                </li>
                            </ul>
                        </div>
                    {% endif %}
                </div>
                
                <!-- Contenu du post -->
                <div class="mb-3">
                    <h4 class="mb-2" style="color: white; font-weight: 600; font-size: 1.2rem;">{{ forum.sujet }}</h4>
                    <p style="color: rgba(255, 255, 255, 0.9); line-height: 1.5; font-size: 1rem;">{{ forum.message|nl2br }}</p>
                </div>
                
                <!-- Actions du post -->
                <div class="d-flex justify-content-between align-items-center">
                    <div class="facebook-actions">
                        <button type="button" class="facebook-btn like-btn" 
                                data-forum-id="{{ forum.id }}"
                                data-liked="{{ app.user ? (forum.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                            <i class="far fa-thumbs-up"></i> 
                            <span class="like-count">{{ forum.getLikesCount() }}</span>
                        </button>
                        <button type="button" class="facebook-btn report-btn" 
                                data-forum-id="{{ forum.id }}"
                                data-reported="{{ app.user ? (forum.signalements|filter(report => report.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                            <i class="far fa-flag"></i> 
                            <span class="report-count">{{ forum.getSignalementsCount() }}</span>
                        </button>
                        <a href="{{ path('post_pdf', {'id': forum.id}) }}" 
   class="facebook-btn" 
   style="text-decoration: none;" 
   target="_blank"
   onclick="this.classList.add('loading'); console.log('PDF download started for forum ID:', {{ forum.id }});">
    <i class="fas fa-file-pdf"></i> Download as PDF
</a>
                    </div>
                </div>
            </div>

            <!-- Section des réponses -->
            <div class="home-panel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        <i class="far fa-comments me-1"></i> 
                        {{ forum.reponses|length }} réponse{{ forum.reponses|length > 1 ? 's' : '' }}
                    </h5>
                </div>
                
                <!-- Formulaire d'ajout de réponse -->
                {% if app.user %}
                    <div class="mb-4 p-3" style="background: rgba(30, 15, 117, 0.05); border-radius: 12px;">
                        <h6 class="mb-3">Ajouter une réponse</h6>
                        <form action="{{ path('app_forum_reponse_create') }}" method="POST">
                            <input type="hidden" name="forum_id" value="{{ forum.id }}">
                            <div class="mb-3">
                                <textarea name="contenu" class="form-control" rows="3" placeholder="Écrivez votre réponse..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-1"></i> Publier
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        <a href="{{ path('app_login') }}">Connectez-vous</a> pour pouvoir répondre.
                    </div>
                {% endif %}

                <!-- Liste des réponses -->
                {% for reponse in forum.reponses %}
                    <div class="p-3 mb-3 facebook-comment" data-reponse-id="{{ reponse.id }}" style="background: rgba(30, 15, 117, 0.03); border-radius: 12px;">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="avatar me-2" style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(145deg, var(--ac-blue), var(--ac-deep)); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 0.7rem;">
                                        {{ reponse.auteur.prenom|first }}{{ reponse.auteur.nom|first }}
                                    </div>
                                    <div>
                                        <strong style="color: var(--ac-deep); font-size: 0.85rem;">{{ reponse.auteur.nom }} {{ reponse.auteur.prenom }}</strong>
                                        <small class="text-muted ms-2">
                                            <i class="fas fa-clock me-1"></i>{{ reponse.dateReponse ? reponse.dateReponse|date('d M \à H:i') : '' }}
                                        </small>
                                    </div>
                                </div>
                                <p class="mb-2" style="color: #333; line-height: 1.4;">{{ reponse.contenu|nl2br }}</p>
                                <div class="facebook-actions">
                                    <button type="button" class="facebook-btn reponse-like-btn" 
                                            data-reponse-id="{{ reponse.id }}"
                                            data-liked="{{ app.user ? (reponse.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                                        <i class="far fa-thumbs-up"></i> 
                                        <span class="like-count">{{ reponse.getLikesCount() }}</span>
                                    </button>
                                    <button type="button" class="facebook-btn reponse-report-btn" 
                                            data-reponse-id="{{ reponse.id }}"
                                            data-reported="{{ app.user ? (reponse.signalements|filter(report => report.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                                        <i class="far fa-flag"></i> 
                                        <span class="report-count">{{ reponse.getSignalementsCount() }}</span>
                                    </button>
                                </div>
                            </div>
                            {% if is_granted('ROLE_ADMIN') or (app.user and app.user == reponse.auteur) %}
                                <div class="ms-2">
                                    <div class="dropdown">
                                        <button class="facebook-btn btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-h"></i>
                                        </button>
                                        <ul class="dropdown-menu">
                                            {% if app.user and app.user == reponse.auteur %}
                                                <li>
                                                    <a href="{{ path('app_forum_reponse_edit', {'id': reponse.id}) }}" class="dropdown-item">
                                                        <i class="fas fa-edit me-1"></i> Modifier
                                                    </a>
                                                </li>
                                            {% endif %}
                                            {% if is_granted('ROLE_ADMIN') or (app.user and app.user == reponse.auteur) %}
                                                <li>
                                                    {{ include('forum_reponse/_delete_form.html.twig') }}
                                                </li>
                                            {% endif %}
                                        </ul>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="text-center py-4">
                        <i class="far fa-comments text-muted" style="font-size: 2rem;"></i>
                        <p class="text-muted mt-2">Soyez le premier à commenter !</p>
                    </div>
                {% endfor %}
            </div>

            <div class="mt-4">
                <a href="{{ path('app_forum_index') }}" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-1"></i> Retour au forum
                </a>
            </div>
        </div>
    </div>
</div>

<style>
.facebook-post {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    border: 1px solid rgba(30, 15, 117, 0.1);
}

/* ===== PAGE CONTAINER ===== */
.public-shell {
    min-height: 100vh;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    padding: 2rem;
    position: relative;
}

.public-shell::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 50%, var(--ac-lavender) 100%);
    opacity: 0.05;
    z-index: -1;
}

/* ===== MAIN POST CARD ===== */
.feature-card.feature-card--forum.facebook-post {
    background: var(--bg-primary);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--border-primary);
    overflow: hidden;
    position: relative;
    backdrop-filter: blur(10px);
    margin-bottom: 2rem;
    transition: var(--transition);
}

.feature-card.feature-card--forum.facebook-post::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    opacity: 0.8;
}

.feature-card.feature-card--forum.facebook-post:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(30,15,117,0.2);
}

/* ===== POST HEADER ===== */
.post-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-secondary);
    position: relative;
}

.post-author {
    display: flex;
    align-items: center;
    gap: 1.25rem;
}

.avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--ac-deep), var(--ac-lavender));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 1.25rem;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
}

.avatar::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(45deg, transparent, rgba(255,255,255,0.2), transparent);
    animation: shine 3s infinite;
}

@keyframes shine {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.author-info strong {
    color: var(--text-primary);
    font-size: 1.125rem;
    font-weight: 700;
    display: block;
    margin-bottom: 0.25rem;
}

.author-info .text-muted {
    color: var(--text-muted);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.author-info .text-muted::before {
    content: '📅';
    font-size: 0.75rem;
}

/* ===== POST ACTIONS ===== */
.post-actions {
    position: relative;
}

.facebook-btn {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

.facebook-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.facebook-btn:hover::before {
    left: 100%;
}

.facebook-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.facebook-btn:active {
    transform: translateY(0);
}

.facebook-btn.liked {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
}

.facebook-btn.liked:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
}

.facebook-btn.reported {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
}

.facebook-btn.reported:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(245, 158, 11, 0.3);
}

.facebook-btn.loading {
    opacity: 0.7;
    pointer-events: none;
}

.facebook-btn.loading::after {
    content: " Génération...";
    margin-left: 0.5rem;
}

/* ===== POST CONTENT ===== */
.post-content {
    padding: 0 2rem 1.5rem;
}

.post-content h2 {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1.3;
    position: relative;
    padding-left: 1rem;
}

.post-content h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 70%;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    border-radius: var(--radius-sm);
}

.post-content p {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    position: relative;
    padding-left: 1rem;
}

.post-content p::before {
    content: '"';
    position: absolute;
    left: -0.5rem;
    top: 0;
    font-size: 3rem;
    color: var(--ac-mid);
    opacity: 0.2;
    font-family: Georgia, serif;
}

/* ===== RESPONSES SECTION ===== */
.home-panel {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    position: relative;
    overflow: hidden;
}

.home-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    opacity: 0.6;
}

.home-panel h5 {
    color: var(--text-primary);
    font-weight: 700;
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.home-panel h5::before {
    content: '💬';
    font-size: 1.5rem;
}

.home-panel h6 {
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 1rem;
    font-size: 1rem;
}

/* ===== RESPONSE FORM ===== */
.home-panel form {
    margin-bottom: 1.5rem;
}

.home-panel textarea {
    border: 2px solid var(--border-primary);
    border-radius: var(--radius-lg);
    padding: 1rem;
    font-size: 1rem;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    transition: var(--transition);
    resize: vertical;
    min-height: 100px;
}

.home-panel textarea:focus {
    outline: none;
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55,133,216,0.1);
    background: var(--bg-primary);
}

.home-panel textarea::placeholder {
    color: var(--text-muted);
}

.home-panel .btn-primary {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

.home-panel .btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.home-panel .btn-primary:hover::before {
    left: 100%;
}

.home-panel .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

/* ===== RESPONSES LIST ===== */
.facebook-comment {
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
    border: 1px solid var(--border-primary);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.facebook-comment::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    opacity: 0.3;
}

.facebook-comment:hover {
    background: rgba(30, 15, 117, 0.05);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.comment-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
}

.comment-author .avatar {
    width: 40px;
    height: 40px;
    font-size: 1rem;
}

.comment-author strong {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 600;
}

.comment-author small {
    color: var(--text-muted);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.comment-author small::before {
    content: '📅';
    font-size: 0.75rem;
}

.comment-content p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
}

.facebook-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.facebook-actions .facebook-btn {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    border-radius: var(--radius-md);
}

.facebook-actions .dropdown {
    position: relative;
}

.facebook-actions .dropdown-menu {
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    min-width: 150px;
    backdrop-filter: blur(10px);
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 1000;
    margin-top: 0.25rem;
}

.facebook-actions .dropdown.show .dropdown-menu {
    display: block;
}

.facebook-actions .dropdown-menu .dropdown-item {
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    display: block;
    transition: var(--transition);
    font-size: 0.875rem;
}

.facebook-actions .dropdown-menu .dropdown-item:hover {
    background: var(--bg-tertiary);
    color: var(--ac-deep);
}

.facebook-actions .dropdown-menu .dropdown-item.text-danger {
    color: #ef4444;
}

.facebook-actions .dropdown-menu .dropdown-item.text-danger:hover {
    background: #fef2f2;
}

.like-count, .report-count {
    font-weight: 700;
    font-size: 0.875rem;
}

/* ===== NAVIGATION ===== */
.mt-4 .btn-outline-primary {
    background: var(--bg-primary);
    color: var(--ac-deep);
    border: 2px solid var(--ac-deep);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.mt-4 .btn-outline-primary:hover {
    background: var(--ac-deep);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

/* ===== ALERTS ===== */
.alert {
    border-radius: var(--radius-lg);
    border: none;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
}

.alert-info {
    background: linear-gradient(135deg, var(--ac-sky), var(--ac-mid));
    color: white;
}

.alert-info::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255,255,255,0.3);
}

.alert-info a {
    color: white;
    text-decoration: underline;
    font-weight: 600;
}

.alert-info a:hover {
    text-decoration: none;
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 768px) {
    .public-shell {
        padding: 1rem;
    }
    
    .feature-card.feature-card--forum.facebook-post {
        margin-bottom: 1.5rem;
        border-radius: var(--radius-xl);
    }
    
    .post-header,
    .post-content,
    .home-panel {
        padding: 1.5rem;
    }
    
    .post-content h2 {
        font-size: 1.5rem;
    }
    
    .post-content p {
        font-size: 1rem;
    }
    
    .avatar {
        width: 48px;
        height: 48px;
        font-size: 1rem;
    }
    
    .facebook-btn {
        padding: 0.5rem 1rem;
        font-size: 0.8rem;
    }
    
    .facebook-actions {
        justify-content: center;
        margin-top: 1rem;
    }
    
    .facebook-actions .facebook-btn {
        flex: 1;
        justify-content: center;
        min-width: 120px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gestion des likes pour les posts (un seul par utilisateur)
    document.querySelectorAll('.like-btn').forEach(button => {
        button.addEventListener('click', function() {
            const forumId = this.dataset.forumId;
            const isLiked = this.dataset.liked === 'true';
            
            fetch(`/forum/${forumId}/like`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    this.dataset.liked = !isLiked;
                    this.classList.toggle('liked');
                    this.querySelector('.like-count').textContent = data.likesCount;
                    
                    // Changer l'icône
                    const icon = this.querySelector('i');
                    if (data.liked) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                    }
                }
            })
            .catch(error => console.error('Error:', error));
        });
    });

    // Gestion des signalements pour les posts (un seul par utilisateur)
    document.querySelectorAll('.report-btn').forEach(button => {
        console.log('Bouton de signalement de forum trouvé:', button);
        
        button.addEventListener('click', function() {
            console.log('Clic sur le bouton de signalement de forum');
            
            const forumId = this.dataset.forumId;
            const isReported = this.dataset.reported === 'true';
            
            console.log('Forum ID:', forumId);
            console.log('Déjà signalé:', isReported);
            
            if (isReported) {
                alert('Vous avez déjà signalé cette publication.');
                return;
            }
            
            if (confirm('Êtes-vous sûr de vouloir signaler cette publication ?')) {
                console.log('Envoi de la requête de signalement de forum...');
                
                fetch(`/forum/${forumId}/report`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    console.log('Réponse reçue du serveur:', response);
                    return response.json();
                })
                .then(data => {
                    console.log('Données reçues:', data);
                    
                    if (data.success) {
                        this.dataset.reported = 'true';
                        this.classList.add('reported');
                        this.querySelector('.report-count').textContent = data.reportsCount;
                        
                        // Changer l'icône
                        const icon = this.querySelector('i');
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        
                        if (data.deleted) {
                            console.log('Forum supprimé, animation en cours...');
                            const post = this.closest('.facebook-post');
                            post.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                            post.style.opacity = '0';
                            post.style.transform = 'scale(0.9)';
                            
                            setTimeout(() => {
                                post.remove();
                                alert('Cette publication a été supprimée car elle a reçu 3 signalements.');
                                // Rediriger vers la liste des forums
                                window.location.href = '/forum';
                            }, 300);
                        } else {
                            console.log('Forum signalé, mais pas encore supprimé. Signalements:', data.reportsCount);
                        }
                    } else {
                        console.error('Erreur dans la réponse:', data);
                        alert('Erreur: ' + (data.message || 'Une erreur est survenue.'));
                    }
                })
                .catch(error => {
                    console.error('Erreur complète:', error);
                    alert('Erreur de connexion: ' + error.message);
                });
            }
        });
    });

    // Gestion des likes pour les commentaires (plusieurs possibles)
    document.querySelectorAll('.reponse-like-btn').forEach(button => {
        button.addEventListener('click', function() {
            const reponseId = this.dataset.reponseId;
            const isLiked = this.dataset.liked === 'true';
            
            fetch(`/forum-reponse/${reponseId}/like`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    this.dataset.liked = !isLiked;
                    this.classList.toggle('liked');
                    this.querySelector('.like-count').textContent = data.likesCount;
                    
                    // Changer l'icône
                    const icon = this.querySelector('i');
                    if (data.liked) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                    }
                }
            })
            .catch(error => console.error('Error:', error));
        });
    });

    // Gestion des signalements pour les commentaires (un seul par utilisateur)
    document.querySelectorAll('.reponse-report-btn').forEach(button => {
        console.log('Bouton de signalement trouvé:', button);
        
        button.addEventListener('click', function() {
            console.log('Clic sur le bouton de signalement');
            
            const reponseId = this.dataset.reponseId;
            const isReported = this.dataset.reported === 'true';
            
            console.log('Réponse ID:', reponseId);
            console.log('Déjà signalé:', isReported);
            
            if (isReported) {
                alert('Vous avez déjà signalé cette réponse.');
                return;
            }
            
            if (confirm('Êtes-vous sûr de vouloir signaler cette réponse ?')) {
                console.log('Envoi de la requête de signalement...');
                
                fetch(`/forum-reponse/${reponseId}/report`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    console.log('Réponse reçue:', response);
                    return response.json();
                })
                .then(data => {
                    console.log('Données reçues:', data);
                    
                    if (data.success) {
                        this.dataset.reported = 'true';
                        this.classList.add('reported');
                        this.querySelector('.report-count').textContent = data.reportsCount;
                        
                        // Changer l'icône
                        const icon = this.querySelector('i');
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        
                        if (data.deleted) {
                            const comment = this.closest('.facebook-comment');
                            comment.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                            comment.style.opacity = '0';
                            comment.style.transform = 'scale(0.9)';
                            
                            setTimeout(() => {
                                comment.remove();
                                alert('Cette réponse a été supprimée car elle a reçu 3 signalements.');
                            }, 300);
                        }
                    } else {
                        alert('Erreur: ' + (data.message || 'Une erreur est survenue.'));
                    }
                })
                .catch(error => {
                    console.error('Erreur complète:', error);
                    alert('Erreur de connexion: ' + error.message);
                });
            }
        });
    });

    // Bouton de test pour le débogage (uniquement en développement)
    {% if app.environment == 'dev' %}
    const testButton = document.createElement('button');
    testButton.textContent = '🧪 TEST SIGNALEMENT';
    testButton.style.cssText = 'position: fixed; top: 10px; right: 10px; z-index: 9999; background: red; color: white; padding: 10px; border: none; cursor: pointer;';
    testButton.onclick = function() {
        console.log('=== TEST AUTOMATIQUE DU SIGNALEMENT ===');
        
        const reportBtn = document.querySelector('.report-btn');
        if (reportBtn) {
            console.log('Bouton de signalement trouvé:', reportBtn);
            console.log('Forum ID:', reportBtn.dataset.forumId);
            console.log('Déjà signalé:', reportBtn.dataset.reported);
            
            // Simuler un clic
            reportBtn.click();
        } else {
            console.error('Bouton de signalement NON TROUVÉ !');
        }
    };
    document.body.appendChild(testButton);
    {% endif %}

    // Gestion personnalisée des dropdowns
    document.querySelectorAll('.dropdown-toggle').forEach(function(dropdownToggle) {
        dropdownToggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const dropdown = this.closest('.dropdown');
            const menu = dropdown.querySelector('.dropdown-menu');
            
            // Fermer tous les autres dropdowns
            document.querySelectorAll('.dropdown').forEach(function(otherDropdown) {
                if (otherDropdown !== dropdown) {
                    otherDropdown.classList.remove('show');
                }
            });
            
            // Basculer le dropdown actuel
            dropdown.classList.toggle('show');
        });
    });

    // Fermer les dropdowns en cliquant ailleurs
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.dropdown')) {
            document.querySelectorAll('.dropdown').forEach(function(dropdown) {
                dropdown.classList.remove('show');
            });
        }
    });
});
</script>
{% endblock %}
