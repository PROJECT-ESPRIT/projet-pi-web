<form method="post" action="{{ path('app_forum_delete', {'id': forum.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce post ?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ forum.id) }}">
    <button type="submit" class="dropdown-item">
        <i class="fas fa-trash"></i> Supprimer
    </button>
</form>
