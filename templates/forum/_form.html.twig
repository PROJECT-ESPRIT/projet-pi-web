{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    <div class="mb-3">
        {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.titre) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.message, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.message, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.message) }}
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i>{{ button_label|default('Enregistrer') }}</button>
        <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary">Annuler</a>
    </div>
{{ form_end(form) }}
