{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ forum.titre }}{% endblock %}

{% block body %}
<div class="bo-page-header">
    <h1><i class="fas fa-edit"></i> Modifier — {{ forum.titre }}</h1>
    <div class="bo-actions">
        <a href="{{ path('app_forum_show', {'id': forum.id}) }}" class="btn btn-outline-secondary"><i class="fas fa-eye me-1"></i>Voir</a>
        <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Retour</a>
    </div>
</div>

<div class="bo-table-card p-3 mb-3">
    {{ include('forum/_form.html.twig', {'button_label': 'Enregistrer'}) }}
</div>

{{ include('forum/_delete_form.html.twig') }}
{% endblock %}
