{% extends 'base.html.twig' %}

{% block title %}Forum{% endblock %}

{% block body %}
<div class="forum-container">
    <!-- Header -->
    <header class="fo-ev-header">
        <h1>
            <i class="fas fa-comments"></i>
            Forum
            <span class="badge">{{ forums|length }} posts</span>
        </h1>
    </header>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="filter-tabs">
            <a href="{{ path('app_forum_index') }}" class="filter-tab filter-tab-all active">
                Tous
                <span class="filter-count">{{ forums|length }}</span>
            </a>
            <a href="{{ path('app_forum_index', {'sort': 'dateCreation'}) }}" class="filter-tab {% if sortBy == 'dateCreation' %}active{% endif %}">
                Récents
            </a>
            <a href="{{ path('app_forum_index', {'sort': 'score'}) }}" class="filter-tab {% if sortBy == 'score' %}active{% endif %}">
                Populaires
            </a>
            <a href="{{ path('app_forum_index', {'sort': 'likes'}) }}" class="filter-tab {% if sortBy == 'likes' %}active{% endif %}">
                Aimés
            </a>
        </div>
        
        <form method="get" action="{{ path('app_forum_index') }}" class="filter-search-form">
            <div class="search-input-wrapper-aligned">
                <i class="fas fa-search search-icon-aligned"></i>
                <input type="text" name="search" placeholder="Chercher un post, un artiste..." value="{{ search }}" class="search-input-aligned">
                <button type="submit" class="search-submit-btn-aligned" title="Lancer la recherche">
                    <i class="fas fa-arrow-right"></i>
                </button>
            </div>
        </form>
        
        <select name="sort" class="filter-sort-aligned">
            <option value="dateCreation" {% if sortBy == 'dateCreation' %}selected{% endif %}>Plus récents</option>
            <option value="score" {% if sortBy == 'score' %}selected{% endif %}>Plus populaires</option>
            <option value="likes" {% if sortBy == 'likes' %}selected{% endif %}>Plus aimés</option>
        </select>
        
        <a href="{{ path('app_forum_new') }}" class="filter-btn-submit-aligned">
            <i class="fas fa-plus"></i>
            Nouveau post
        </a>
    </div>
    <main class="forum-main">
        <!-- Posts Feed -->
        <div class="posts-feed">
            {% for forum in forums %}
                <article class="post-card" data-forum-id="{{ forum.id }}">
                    <!-- Header : Auteur et date en haut à gauche -->
                    <header class="post-header">
                        <div class="post-author-info">
                            <div class="author-avatar">
                                <div class="avatar-placeholder">
                                    {{ forum.nom|first }}{{ forum.prenom|first }}
                                </div>
                            </div>
                            <div class="author-details">
                                <div class="author-name">
                                    {{ forum.nom }} {{ forum.prenom }}
                                    <span class="author-score-badge" title="Score du post">
                                        <i class="fas fa-star"></i>
                                        {{ forum.getScore() }}
                                    </span>
                                </div>
                                <div class="post-date">{{ forum.dateCreation ? forum.dateCreation|date('d/m/Y') : '' }}</div>
                            </div>
                        </div>
                        {% if is_granted('ROLE_ADMIN') or (app.user and app.user.email == forum.email) %}
                            <div class="post-menu-dropdown">
                                <button class="post-menu-btn" onclick="togglePostMenu({{ forum.id }})" aria-label="Options">
                                    <i class="fas fa-ellipsis-h"></i>
                                </button>
                                <div class="post-menu-content" id="post-menu-{{ forum.id }}">
                                    <a href="{{ path('app_forum_edit', {'id': forum.id, 'search': search, 'sort': sortBy, 'order': order}) }}" class="post-menu-item">
                                        <i class="fas fa-edit"></i>
                                        Modifier
                                    </a>
                                    <form method="post" action="{{ path('app_forum_delete', {'id': forum.id, 'search': search, 'sort': sortBy, 'order': order}) }}" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce post ?');" 
                                          style="display: contents;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ forum.id) }}">
                                        <button type="submit" class="post-menu-item post-menu-item-danger">
                                            <i class="fas fa-trash"></i>
                                            Supprimer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endif %}
                    </header>

                    <!-- Corps : Contenu du post -->
                    <div class="post-body">
                        <h2 class="post-title">{{ forum.sujet }}</h2>
                        <div class="post-content">{{ forum.message|nl2br }}</div>
                    </div>

                    <!-- Actions : Barre horizontale style Facebook -->
                    <div class="post-actions-bar">
                        <button class="action-btn like-btn {% if app.user and (forum.likes|filter(like => like.user == app.user)|length > 0) %}liked{% endif %}" 
                                type="button"
                                data-forum-id="{{ forum.id }}"
                                data-liked="{{ app.user ? (forum.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                            <i class="{% if app.user and (forum.likes|filter(like => like.user == app.user)|length > 0) %}fas{% else %}far{% endif %} fa-heart"></i>
                            <span>Like</span>
                            <span class="count">{{ forum.getLikesCount() }}</span>
                        </button>
                        <button class="action-btn comment-btn" type="button" onclick="toggleCommentForm({{ forum.id }})">
                            <i class="far fa-comment"></i>
                            <span>Commenter</span>
                            <span class="count">{{ forum.reponses|length }}</span>
                        </button>
                        <button class="action-btn report-btn {% if app.user and (forum.signalements|filter(report => report.user == app.user)|length > 0) %}reported{% endif %}" 
                                type="button"
                                data-forum-id="{{ forum.id }}"
                                data-reported="{{ app.user ? (forum.signalements|filter(report => report.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                            <i class="{% if app.user and (forum.signalements|filter(report => report.user == app.user)|length > 0) %}fas{% else %}far{% endif %} fa-flag"></i>
                            <span>Signaler</span>
                        </button>
                    </div>

                    <!-- Section Réponses : Zone avec décalage visuel -->
                    <div class="post-responses" id="responses-{{ forum.id }}" style="display: none;">
                        <!-- Formulaire de commentaire -->
                        <div class="comment-form-container" id="comment-form-{{ forum.id }}">
                            {% if app.user %}
                                <form id="comment-form-{{ forum.id }}" class="comment-form" enctype="multipart/form-data">
                                    <input type="hidden" name="forum_id" value="{{ forum.id }}">
                                    <div class="comment-input-wrapper">
                                        <textarea name="contenu" id="comment-textarea-{{ forum.id }}" placeholder="Écrivez votre commentaire ou enregistrez un message vocal..." required></textarea>
                                        <div class="voice-buttons-group">
                                            <button type="button" class="voice-ai-btn" id="voiceAiBtn-{{ forum.id }}" onclick="toggleVoiceTranscription({{ forum.id }})" title="Transformer la voix en texte">
                                                <i class="fas fa-microphone"></i>
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <!-- Voice Recording Preview (hidden by default) -->
                                    <div class="voice-preview-container" id="voicePreviewContainer-{{ forum.id }}" style="display: none;">
                                        <audio id="voicePreview-{{ forum.id }}" controls style="width: 100%;"></audio>
                                        <div class="voice-controls-mini">
                                            <button type="button" class="voice-transcribe-btn" onclick="transcribeAudio({{ forum.id }})">
                                                <i class="fas fa-magic"></i> Transformer en texte
                                            </button>
                                            <button type="button" class="voice-delete-mini-btn" onclick="deleteVoiceRecording({{ forum.id }})">
                                                <i class="fas fa-trash"></i> Supprimer
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <!-- AI Transcription Status -->
                                    <div class="ai-transcription-status" id="aiStatus-{{ forum.id }}" style="display: none;">
                                        <div class="ai-status-content">
                                            <i class="fas fa-brain ai-pulse"></i>
                                            <span>Transcription en cours...</span>
                                        </div>
                                    </div>
                                    
                                    <input type="hidden" name="voice_data" id="voiceDataInput-{{ forum.id }}">
                                    
                                    <button type="submit" class="submit-comment-btn">
                                        <i class="fas fa-paper-plane"></i> Publier
                                    </button>
                                </form>
                            {% else %}
                                <div class="login-prompt">
                                    <a href="{{ path('app_login') }}">Connectez-vous</a> pour commenter.
                                </div>
                            {% endif %}
                        </div>

                        <!-- Liste des réponses avec indentation -->
                        {% if forum.reponses|length > 0 %}
                            <div class="responses-list">
                                {% for reponse in forum.reponses %}
                                    <div class="response-item" data-reponse-id="{{ reponse.id }}">
                                        <div class="response-header">
                                            <div class="response-avatar">
                                                {{ reponse.auteur.prenom|first }}{{ reponse.auteur.nom|first }}
                                            </div>
                                            <div class="response-info">
                                                <div class="response-author">{{ reponse.auteur.nom }} {{ reponse.auteur.prenom }}</div>
                                                <div class="response-date">{{ reponse.dateReponse ? reponse.dateReponse|date('d/m/Y') : '' }}</div>
                                            </div>
                                            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.id == reponse.auteur.id) %}
                                                <div class="response-menu-dropdown">
                                                    <button class="response-menu-btn" onclick="toggleResponseMenu({{ reponse.id }})" aria-label="Options">
                                                        <i class="fas fa-ellipsis-h"></i>
                                                    </button>
                                                    <div class="response-menu-content" id="response-menu-{{ reponse.id }}">
                                                        {% if app.user and reponse.auteur and app.user.id == reponse.auteur.id %}
                                                            <a href="{{ path('app_forum_reponse_edit', {'id': reponse.id, 'search': search, 'sort': sortBy, 'order': order}) }}" class="response-menu-item">
                                                                <i class="fas fa-edit"></i>
                                                                Modifier
                                                            </a>
                                                        {% endif %}
                                                        {% if is_granted('ROLE_ADMIN') or (app.user and reponse.auteur and app.user.id == reponse.auteur.id) %}
                                                            <form method="post" action="{{ path('app_forum_reponse_delete', {'id': reponse.id, 'search': search, 'sort': sortBy, 'order': order}) }}" 
                                                                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce commentaire ?');" 
                                                                  style="display: contents;">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reponse.id) }}">
                                                                <button type="submit" class="response-menu-item response-menu-item-danger">
                                                                    <i class="fas fa-trash"></i>
                                                                    Supprimer
                                                                </button>
                                                            </form>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </div>
                                        <div class="response-content">{{ reponse.contenu|nl2br }}</div>
                                        {% if reponse.voiceMessage %}
                                            <div class="voice-message-player">
                                                <audio controls preload="none" style="width: 100%; max-width: 300px;">
                                                    <source src="{{ asset(reponse.voiceMessage) }}" type="audio/wav">
                                                    <source src="{{ asset(reponse.voiceMessage) }}" type="audio/mpeg">
                                                    <source src="{{ asset(reponse.voiceMessage) }}" type="audio/ogg">
                                                    Votre navigateur ne supporte pas l'élément audio.
                                                </audio>
                                                <div class="voice-message-label">
                                                    <i class="fas fa-microphone"></i> Message vocal
                                                </div>
                                            </div>
                                        {% endif %}
                                        <div class="response-actions">
                                            <button class="response-action-btn response-like-btn" 
                                                    data-reponse-id="{{ reponse.id }}"
                                                    data-liked="{{ app.user ? (reponse.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                                                <i class="{% if app.user and (reponse.likes|filter(like => like.user == app.user)|length > 0) %}fas{% else %}far{% endif %} fa-heart"></i>
                                                <span>{{ reponse.getLikesCount() }}</span>
                                            </button>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="empty-responses">
                                <i class="far fa-comments"></i>
                                <p>Soyez le premier à commenter !</p>
                            </div>
                        {% endif %}
                    </div>
                </article>
            {% else %}
                <div class="fo-empty">
                    <i class="fas fa-comments"></i>
                    <h3>Aucune publication</h3>
                    <p>
                        Soyez le premier à partager vos pensées avec la communauté.
                    </p>
                    <a href="{{ path('app_forum_new') }}" class="filter-btn-submit">
                        <i class="fas fa-plus"></i>
                        Créer le premier post
                    </a>
                </div>
            {% endfor %}
        </div>
    </main>
</div>

<style>
/* ===== CSS VARIABLES ===== */
:root {
    --ac-deep: #1E0F75;
    --ac-mid: #3785D8;
    --ac-lavender: #BF8CE1;
    --ac-sky: #ADC6E5;
    --ac-pink: #EBB2C3;
    --text-primary: #1a1a1a;
    --text-secondary: #6b7280;
    --text-muted: #9ca3af;
    --bg-primary: #ffffff;
    --bg-secondary: #f8fafc;
    --bg-tertiary: #f1f5f9;
    --border-primary: #e2e8f0;
    --border-secondary: #f3f4f6;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
    --shadow-md: 0 4px 6px rgba(0,0,0,0.1), 0 2px 4px rgba(0,0,0,0.06);
    --shadow-lg: 0 10px 25px rgba(0,0,0,0.1), 0 6px 10px rgba(0,0,0,0.08);
    --shadow-xl: 0 20px 40px rgba(30,15,117,0.15);
    --radius-sm: 6px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --radius-2xl: 24px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ===== FORUM CONTAINER ===== */
.forum-container {
    min-height: 100vh;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    font-family: 'Sora', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    padding: 2rem;
    position: relative;
}

.forum-container::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 50%, var(--ac-lavender) 100%);
    opacity: 0.05;
    z-index: -1;
}

/* ===== HEADER ===== */
.fo-ev-header {
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    margin-bottom: 2rem; 
    padding: 1.5rem 2rem;
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
}

.fo-ev-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--ac-deep), var(--ac-mid), var(--ac-lavender));
}

.fo-ev-header h1 {
    margin: 0; 
    font-family: 'Sora', sans-serif;
    font-size: 2rem; 
    font-weight: 800; 
    color: var(--text-primary);
    display: flex; 
    align-items: center; 
    gap: 1rem;
    position: relative;
}

.fo-ev-header h1::before {
    content: '💬';
    font-size: 2.5rem;
    animation: bounce 2s infinite;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
}

.fo-ev-header .badge { 
    font-size: 0.875rem; 
    border-radius: var(--radius-lg); 
    background: linear-gradient(135deg, var(--ac-mid), var(--ac-lavender));
    color: white;
    padding: 0.5rem 1rem;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
}

/* ===== MAIN LAYOUT ===== */
.forum-main {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
}

/* ===== POSTS FEED ===== */
.posts-feed {
    flex: 1;
    min-width: 0;
}

/* ===== FILTER BAR ===== */
.filter-bar {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    margin-bottom: 2rem;
    display: flex; 
    align-items: center; 
    gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    backdrop-filter: blur(10px);
}

.filter-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.filter-tabs {
    display: flex; 
    gap: 0.5rem;
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    padding: 0.5rem;
    flex: 1;
}

.filter-tab {
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: transparent;
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
    text-decoration: none; 
    display: inline-flex; 
    align-items: center;
    position: relative;
    overflow: hidden;
}

.filter-tab::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    opacity: 0;
    transition: var(--transition);
}

.filter-tab:hover::before {
    opacity: 0.1;
}

.filter-tab.active {
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 55%, var(--ac-lavender) 100%); 
    color: #fff; 
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
}

.filter-tab.active::before {
    opacity: 0;
}

.filter-tab:not(.active):hover {
    background: rgba(30,15,117,0.1);
    color: var(--ac-deep);
    transform: translateY(-1px);
}
.filter-search-wrap {
    display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;
    flex: 1; min-width: 0;
}
.filter-search-wrap .filter-search { flex: 1; min-width: 160px; }
.filter-search-wrap .filter-sort { min-width: 140px; }
.filter-tab.filter-tab-all {
    cursor: default; pointer-events: none;
}
.filter-toggle-adv { position: relative; }
.filter-toggle-adv .filter-adv-dot {
    position: absolute; top: 6px; right: 6px;
    width: 6px; height: 6px; border-radius: 50%;
    background: #fff; opacity: 0.9; display: none;
}
.filter-toggle-adv.active .filter-adv-dot { display: block; }
.filter-adv-title {
    font-size: 0.8rem; font-weight: 700; color: #1E0F75;
    margin-bottom: 0.6rem; display: block;
}
.filter-adv-actions { min-width: auto; }
.visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}
/* ===== FILTER BAR - ALIGNEMENT PARFAIT SUR UNE LIGNE ===== */
.filter-bar {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    padding: 1rem 1.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
    flex-wrap: nowrap;
    position: relative;
    backdrop-filter: blur(10px);
}

.filter-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.filter-tabs {
    display: flex; 
    gap: 0.5rem;
