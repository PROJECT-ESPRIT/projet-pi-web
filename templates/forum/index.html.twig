                    showNotification('Erreur lors de la suppression', 'error');
                });
            });
        });
    });

    // Voice Recording Functionality for Forum Index
    const voiceRecorders = {};
    const speechRecognizers = {};

    window.toggleVoiceRecording = function(forumId) {
        const microBtn = document.getElementById(`voiceMicroBtn-${forumId}`);
        const previewContainer = document.getElementById(`voicePreviewContainer-${forumId}`);
        const voicePreview = document.getElementById(`voicePreview-${forumId}`);
        const voiceDataInput = document.getElementById(`voiceDataInput-${forumId}`);
        const textarea = document.getElementById(`comment-textarea-${forumId}`);
        
        if (microBtn.classList.contains('recording')) {
            // Stop recording
            const recorder = voiceRecorders[forumId];
            if (recorder && recorder.mediaRecorder) {
                recorder.mediaRecorder.stop();
                recorder.stream.getTracks().forEach(track => track.stop());
                delete voiceRecorders[forumId];
            }
            
            microBtn.classList.remove('recording');
            microBtn.innerHTML = '<i class="fas fa-microphone"></i>';
            
        } else {
            // Start recording
            try {
                navigator.mediaDevices.getUserMedia({ audio: true })
                    .then(mediaStream => {
                        const mediaRecorder = new MediaRecorder(mediaStream);
                        const audioChunks = [];
                        
                        voiceRecorders[forumId] = {
                            mediaRecorder: mediaRecorder,
                            stream: mediaStream,
                            audioChunks: audioChunks
                        };

                        mediaRecorder.ondataavailable = (event) => {
                            audioChunks.push(event.data);
                        };

                        mediaRecorder.onstop = () => {
                            const audioBlob = new Blob(audioChunks, { type: 'audio/wav' });
                            const audioUrl = URL.createObjectURL(audioBlob);
                            
                            voicePreview.src = audioUrl;
                            previewContainer.style.display = 'block';
                            
                            // Convert blob to base64 for form submission
                            const reader = new FileReader();
                            reader.onloadend = () => {
                                voiceDataInput.value = reader.result;
                                // Clear textarea when voice is recorded
                                textarea.value = '';
                                textarea.placeholder = 'Message vocal enregistré (cliquez sur le micro pour enregistrer un nouveau message)...';
                            };
                            reader.readAsDataURL(audioBlob);
                        };

                        mediaRecorder.start();
                        
                        // Update UI
                        microBtn.classList.add('recording');
                        microBtn.innerHTML = '<i class="fas fa-stop"></i>';
                        previewContainer.style.display = 'none';
                        
                    }).catch(error => {
                        console.error('Error accessing microphone:', error);
                        alert('Erreur: Impossible d\'accéder au microphone');
                    });
            } catch (error) {
                console.error('Error:', error);
                alert('Erreur: Impossible d\'accéder au microphone');
            }
        }
    };

    // AI Voice Transcription Functionality
    window.toggleVoiceTranscription = function(forumId) {
        const aiBtn = document.getElementById(`voiceAiBtn-${forumId}`);
        const aiStatus = document.getElementById(`aiStatus-${forumId}`);
        const textarea = document.getElementById(`comment-textarea-${forumId}`);
        
        if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
            alert('La reconnaissance vocale n\'est pas supportée par votre navigateur. Essayez Chrome ou Edge.');
            return;
        }
        
        if (aiBtn.classList.contains('transcribing')) {
            // Stop transcription
            const recognizer = speechRecognizers[forumId];
            if (recognizer) {
                recognizer.stop();
                delete speechRecognizers[forumId];
            }
            
            aiBtn.classList.remove('transcribing');
            aiBtn.innerHTML = '<i class="fas fa-microphone"></i>';
            aiStatus.style.display = 'none';
            
        } else {
            // Start transcription
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            const recognizer = new SpeechRecognition();
            
            speechRecognizers[forumId] = recognizer;
            
            recognizer.lang = 'fr-FR';
            recognizer.continuous = true;
            recognizer.interimResults = true;
            
            let finalTranscript = '';
            
            recognizer.onresult = function(event) {
                let interimTranscript = '';
                
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const transcript = event.results[i][0].transcript;
                    if (event.results[i].isFinal) {
                        finalTranscript += transcript + ' ';
                    } else {
                        interimTranscript += transcript;
                    }
                }
                
                textarea.value = finalTranscript + interimTranscript;
                textarea.placeholder = 'Transcription automatique en cours...';
            };
            
            recognizer.onerror = function(event) {
                console.error('Speech recognition error:', event.error);
                alert('Erreur de reconnaissance vocale: ' + event.error);
                aiBtn.classList.remove('transcribing');
                aiBtn.innerHTML = '<i class="fas fa-microphone"></i>';
                aiStatus.style.display = 'none';
            };
            
            recognizer.onend = function() {
                aiBtn.classList.remove('transcribing');
                aiBtn.innerHTML = '<i class="fas fa-microphone"></i>';
                aiStatus.style.display = 'none';
                textarea.placeholder = 'Écrivez votre commentaire ou enregistrez un message vocal...';
            };
            
            // Clear textarea and start
            textarea.value = '';
            recognizer.start();
            
            // Update UI
            aiBtn.classList.add('transcribing');
            aiBtn.innerHTML = '<i class="fas fa-stop"></i>';
            aiStatus.style.display = 'block';
            textarea.placeholder = 'Parlez maintenant, je vous écoute...';
        }
    };

    // Transcribe recorded audio to text
    window.transcribeAudio = function(forumId) {
        const voicePreview = document.getElementById(`voicePreview-${forumId}`);
        const voiceDataInput = document.getElementById(`voiceDataInput-${forumId}`);
        const textarea = document.getElementById(`comment-textarea-${forumId}`);
        const aiStatus = document.getElementById(`aiStatus-${forumId}`);
        
        if (!voicePreview.src) {
            alert('Aucun audio à transcrire');
            return;
        }
        
        // Show AI status
        aiStatus.style.display = 'block';
        aiStatus.querySelector('span').textContent = 'Envoi de l\'audio pour transcription...';
        
        // Convert audio blob to file for upload
        fetch(voicePreview.src)
            .then(res => res.blob())
            .then(blob => {
                const file = new File([blob], 'audio.wav', { type: 'audio/wav' });
                const formData = new FormData();
                
                // Add form data
                formData.append('forum_id', document.querySelector(`input[name="forum_id"]`).value);
                formData.append('voice_message', file);
                formData.append('transcribe_audio', 'true');
                formData.append('contenu', ''); // Empty content since we're transcribing
                
                // Send to backend for transcription
                fetch('/forum/reponse/create', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    aiStatus.style.display = 'none';
                    
                    if (data.success) {
                        // Clear voice data since we're using text now
                        voiceDataInput.value = '';
                        document.getElementById(`voicePreviewContainer-${forumId}`).style.display = 'none';
                        
                        // Show success message and reload or update UI
                        const successMsg = document.createElement('div');
                        successMsg.style.cssText = 'position: fixed; top: 20px; right: 20px; background: #10b981; color: white; padding: 1rem; border-radius: 8px; z-index: 1000;';
                        successMsg.innerHTML = '<i class="fas fa-check"></i> Transcription terminée et commentaire publié!';
                        document.body.appendChild(successMsg);
                        
                        setTimeout(() => {
                            document.body.removeChild(successMsg);
                            // Reload the page to show the new comment
                            window.location.reload();
                        }, 2000);
                    } else {
                        alert('Erreur de transcription: ' + (data.message || 'Erreur inconnue'));
                    }
                })
                .catch(error => {
                    aiStatus.style.display = 'none';
                    console.error('Error:', error);
                    alert('Erreur lors de la transcription: ' + error.message);
                });
            })
            .catch(error => {
                aiStatus.style.display = 'none';
                console.error('Error converting audio:', error);
                alert('Erreur lors de la préparation de l\'audio');
            });
    };

    window.deleteVoiceRecording = function(forumId) {
        // Reset everything
        if (voiceRecorders[forumId]) {
            delete voiceRecorders[forumId];
        }
        if (speechRecognizers[forumId]) {
            speechRecognizers[forumId].stop();
            delete speechRecognizers[forumId];
        }
        
        const microBtn = document.getElementById(`voiceMicroBtn-${forumId}`);
        const aiBtn = document.getElementById(`voiceAiBtn-${forumId}`);
        const previewContainer = document.getElementById(`voicePreviewContainer-${forumId}`);
        const voicePreview = document.getElementById(`voicePreview-${forumId}`);
        const voiceDataInput = document.getElementById(`voiceDataInput-${forumId}`);
        const textarea = document.getElementById(`comment-textarea-${forumId}`);
        const aiStatus = document.getElementById(`aiStatus-${forumId}`);
        
        voicePreview.src = '';
        previewContainer.style.display = 'none';
        voiceDataInput.value = '';
        aiStatus.style.display = 'none';
        
        microBtn.classList.remove('recording');
        microBtn.innerHTML = '<i class="fas fa-microphone"></i>';
        
        aiBtn.classList.remove('transcribing');
        aiBtn.innerHTML = '<i class="fas fa-microphone"></i>';
        
        textarea.placeholder = 'Écrivez votre commentaire ou enregistrez un message vocal...';
    };

    // Form submission validation for voice comments
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.comment-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                const textarea = this.querySelector('textarea[name="contenu"]');
                const voiceDataInput = this.querySelector('input[name="voice_data"]');
                
                // Check if either text or voice is provided
                if (!textarea.value.trim() && !voiceDataInput.value) {
                    e.preventDefault();
                    alert('Veuillez écrire un message ou enregistrer un message vocal');
                }
            });
        });
    });
});
</script>
{% endblock %}
