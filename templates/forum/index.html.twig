/* ===== MENUS DROPDOWN STYLE FACEBOOK ===== */
.post-menu-dropdown,
.response-menu-dropdown {
    position: relative;
}

.post-menu-btn,
.response-menu-btn {
    background: transparent;
    border: none;
    padding: 0.5rem;
    border-radius: 50%;
    cursor: pointer;
    color: var(--text-secondary);
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
}

.post-menu-btn:hover,
.response-menu-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
}

.post-menu-content,
.response-menu-content {
    position: absolute;
    top: 100%;
    right: 0;
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    z-index: 1000;
    min-width: 150px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: var(--transition);
    overflow: hidden;
}

.post-menu-content.show,
.response-menu-content.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(5px);
}

.post-menu-item,
.response-menu-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    text-decoration: none;
    border: none;
    background: transparent;
    width: 100%;
    text-align: left;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
}

.post-menu-item:hover,
.response-menu-item:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
}

.post-menu-item i,
.response-menu-item i {
    width: 16px;
    text-align: center;
}

.post-menu-item-danger,
.response-menu-item-danger {
    color: #dc3545 !important;
}

.post-menu-item-danger:hover,
.response-menu-item-danger:hover {
    background: rgba(220, 53, 69, 0.1) !important;
    color: #dc3545 !important;
}

