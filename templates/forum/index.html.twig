    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: transparent;
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
    text-decoration: none; 
    display: inline-flex; 
    align-items: center;
    position: relative;
    overflow: hidden;
}

.filter-tab::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    opacity: 0;
    transition: var(--transition);
}

.filter-tab:hover::before {
    opacity: 0.1;
}

.filter-tab.active {
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 55%, var(--ac-lavender) 100%); 
    color: #fff; 
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
}

.filter-tab.active::before {
    opacity: 0;
}

.filter-tab:not(.active):hover {
    background: rgba(30,15,117,0.1);
    color: var(--ac-deep);
    transform: translateY(-1px);
}

.filter-search-form {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 250px;
}

.search-input-wrapper-aligned {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--bg-tertiary);
    border: 2px solid var(--border-primary);
    border-radius: var(--radius-lg);
    transition: var(--transition);
    height: 48px;
    width: 100%;
}

.search-input-wrapper-aligned:focus-within {
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55,133,216,0.1);
    background: var(--bg-primary);
}

.search-icon-aligned {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 1rem;
    transition: var(--transition);
    z-index: 5;
    pointer-events: none;
}

.search-input-wrapper-aligned:focus-within .search-icon-aligned {
    color: var(--ac-mid);
}

.search-input-aligned {
    flex: 1;
    border: none;
    background: transparent;
    padding: 0 45px 0 45px !important;
    font-size: 0.95rem;
    color: var(--text-primary);
    outline: none;
    height: 100%;
    box-sizing: border-box;
    font-weight: 500;
}

.search-input-aligned::placeholder {
    color: var(--text-muted);
    font-weight: 400;
}

.search-submit-btn-aligned {
    position: absolute;
    right: 12px;
    background: var(--ac-mid);
    border: none;
    border-radius: 50%;
    width: 32px;
