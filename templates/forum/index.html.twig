    // Gestion des suppressions en AJAX pour rester sur la même page
    document.addEventListener('DOMContentLoaded', function() {
        // Gérer la suppression des posts
        document.querySelectorAll('form[action*="/forum/"][action*="/delete"]').forEach(form => {
            if (form.action.includes('/forum/') && !form.action.includes('/forum/reponse/')) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    
                    if (!confirm('Êtes-vous sûr de vouloir supprimer ce post ?')) {
                        return;
                    }
                    
                    const formData = new FormData(this);
                    const forumId = this.action.match(/\/forum\/(\d+)\/delete/)[1];
                    
                    fetch(this.action, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (response.ok) {
                            // Supprimer le post du DOM
                            const postCard = document.querySelector(`[data-forum-id="${forumId}"]`);
                            if (postCard) {
                                postCard.style.transition = 'opacity 0.3s, transform 0.3s';
