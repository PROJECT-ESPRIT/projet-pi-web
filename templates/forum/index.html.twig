            if (confirm('Êtes-vous sûr de vouloir signaler cette publication ?')) {
                fetch(`/forum/${forumId}/report`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
