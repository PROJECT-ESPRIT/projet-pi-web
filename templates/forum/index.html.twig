    line-height: 1.4;
    transition: var(--transition);
    width: 100%;
    box-sizing: border-box;
}

.comment-input-wrapper textarea:focus {
    outline: none;
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55, 133, 216, 0.1);
}

.voice-buttons-group {
    position: absolute;
    right: 8px;
    bottom: 8px;
    display: flex;
    gap: 4px;
    z-index: 10;
}

.voice-micro-btn, .voice-ai-btn {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    font-size: 0.9rem;
    box-shadow: 0 2px 8px rgba(55, 133, 216, 0.3);
}

.voice-ai-btn {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    box-shadow: 0 2px 8px rgba(139, 92, 246, 0.3);
}

.voice-micro-btn:hover, .voice-ai-btn:hover {
    transform: scale(1.05);
}

.voice-micro-btn:hover {
    box-shadow: 0 4px 12px rgba(55, 133, 216, 0.4);
}

.voice-ai-btn:hover {
    box-shadow: 0 4px 12px rgba(139, 92, 246, 0.4);
}

.voice-micro-btn.recording {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    animation: pulse 1.5s infinite;
}

.voice-ai-btn.transcribing {
    background: linear-gradient(135deg, #10b981, #059669);
    animation: pulse 1.5s infinite;
}

.voice-preview-container {
    margin-top: 0.75rem;
    padding: 0.75rem;
    background: rgba(55, 133, 216, 0.05);
    border: 1px solid rgba(55, 133, 216, 0.2);
    border-radius: var(--radius-md);
}

.voice-preview-container audio {
    width: 100%;
    height: 40px;
    border-radius: var(--radius-sm);
}

.voice-controls-mini {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
    gap: 0.5rem;
}

.voice-transcribe-btn {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: white;
    border: none;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 0.4rem;
}

.voice-transcribe-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(139, 92, 246, 0.3);
}

.voice-delete-mini-btn {
    background: linear-gradient(135deg, #6b7280, #4b5563);
    color: white;
    border: none;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 0.4rem;
}

.voice-delete-mini-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(107, 114, 128, 0.3);
}

.ai-transcription-status {
    margin-top: 0.75rem;
    padding: 0.75rem;
    background: rgba(139, 92, 246, 0.05);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: var(--radius-md);
}

.ai-status-content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #8b5cf6;
    font-size: 0.9rem;
    font-weight: 500;
}

.ai-pulse {
    animation: aiPulse 1.5s infinite;
}

@keyframes aiPulse {
    0% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
    100% { opacity: 1; transform: scale(1); }
}

.comment-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.submit-comment-btn {
    align-self: flex-end;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    box-shadow: 0 2px 8px rgba(55, 133, 216, 0.3);
}

.submit-comment-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(55, 133, 216, 0.4);
}

@keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.7; }
    100% { opacity: 1; }
}

/* ===== VOICE MESSAGE PLAYER ===== */
.voice-message-player {
    margin-top: 0.75rem;
    padding: 0.75rem;
    background: rgba(55, 133, 216, 0.05);
    border: 1px solid rgba(55, 133, 216, 0.2);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.voice-message-player audio {
    flex: 1;
    height: 32px;
}

.voice-message-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ac-mid);
    font-weight: 600;
    white-space: nowrap;
}

.voice-message-label i {
    color: var(--ac-deep);
}

/* ===== LISTE DES RÉPONSES ===== */
.responses-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
}

.response-item {
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    padding: 0.75rem;
    border: 1px solid var(--border-secondary);
    margin-left: 1.5rem;
    position: relative;
    transition: var(--transition);
    box-shadow: none;
}

.response-item::before {
    content: '';
    position: absolute;
    left: -0.75rem;
    top: 0.75rem;
    width: 0.35rem;
    height: 0.35rem;
    background: var(--ac-mid);
    border-radius: 50%;
    opacity: 0.6;
}

.response-item:hover {
    background: var(--bg-primary);
    box-shadow: var(--shadow-sm);
}

.response-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    justify-content: space-between;
}

.response-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--ac-sky), var(--ac-mid));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 0.7rem;
    flex-shrink: 0;
}

.response-info {
    flex: 1;
}

.response-author {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.8rem;
    margin-bottom: 0.1rem;
}

.response-date {
    color: var(--text-muted);
    font-size: 0.7rem;
}

.response-content {
    color: var(--text-secondary);
    line-height: 1.4;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    background: transparent;
    padding: 0;
    border: none;
    border-radius: 0;
}

.response-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.3rem;
}

.response-action-btn {
    background: transparent;
    border: 1px solid var(--border-secondary);
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
}

.response-action-btn:hover {
    background: var(--bg-primary);
    color: var(--ac-deep);
    border-color: var(--ac-mid);
}

.response-action-btn.liked {
    color: #ef4444;
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
}

.response-actions-menu {
    position: relative;
}

/* ===== POST HEADER ===== */
.post-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-secondary);
}

.post-author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
}

.author-avatar {
    position: relative;
}

.avatar-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--ac-deep), var(--ac-mid));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 1rem;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
}

.avatar-placeholder:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-md);
}

.author-details {
    flex: 1;
}

.author-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
    margin-bottom: 0.2rem;
}

.post-date {
    color: var(--text-muted);
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
}

.post-date::before {
    content: '📅';
    font-size: 0.7rem;
}

.post-actions {
    position: relative;
    margin-left: auto;
    flex-shrink: 0;
}

.post-actions .action-btn {
    background: transparent;
    border: none;
    padding: 0.5rem;
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
}

.post-actions .action-btn:hover {
    background: var(--bg-tertiary);
    color: var(--ac-deep);
}

.post-actions .dropdown-menu {
    position: absolute;
    top: 100%;
    right: 0;
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    min-width: 150px;
    z-index: 1000;
    display: none;
}

.post-actions .dropdown.show .dropdown-menu {
    display: block;
}

.post-actions .dropdown-menu .dropdown-item {
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition);
    font-size: 0.875rem;
}

.post-actions .dropdown-menu .dropdown-item:hover {
    background: var(--bg-tertiary);
    color: var(--ac-deep);
}

.tag:hover::before {
    left: 100%;
}

.tag:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
}

.tag-discussion {
    background: linear-gradient(135deg, var(--ac-sky), var(--ac-mid));
    color: white;
    border-color: var(--ac-mid);
}

.tag-question {
    background: linear-gradient(135deg, var(--ac-pink), var(--ac-lavender));
    color: white;
    border-color: var(--ac-lavender);
}

.post-engagement {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.engagement-btn {
    background: var(--bg-primary);
    border: 2px solid var(--border-primary);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-lg);
    color: var(--text-secondary);
    font-size: 0.875rem;
    cursor: pointer;
    transition: var(--transition);
    font-weight: 600;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.engagement-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(30,15,117,0.05), transparent);
    transition: left 0.3s;
}

.engagement-btn:hover::before {
    left: 100%;
}

.engagement-btn.pdf-btn {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border-color: var(--ac-deep);
}

.engagement-btn.pdf-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.engagement-btn.report-btn:hover {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
    border-color: #f59e0b;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(245, 158, 11, 0.3);
}

.engagement-btn:hover:not(.pdf-btn):not(.report-btn) {
    background: var(--bg-tertiary);
    color: var(--ac-deep);
    border-color: var(--ac-mid);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.engagement-btn i {
    font-size: 1rem;
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 768px) {
