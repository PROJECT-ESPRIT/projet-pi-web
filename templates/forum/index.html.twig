{% extends 'base.html.twig' %}

{% block title %}Forum{% endblock %}

{% block body %}
<div class="forum-container">
    <!-- Header -->
    <header class="fo-ev-header">
        <h1>
            <i class="fas fa-comments"></i>
            Forum
            <span class="badge">{{ forums|length }} posts</span>
        </h1>
    </header>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="filter-tabs">
            <a href="{{ path('app_forum_index') }}" class="filter-tab filter-tab-all active">
                Tous
                <span class="filter-count">{{ forums|length }}</span>
            </a>
            <a href="{{ path('app_forum_index', {'sort': 'dateCreation'}) }}" class="filter-tab {% if sortBy == 'dateCreation' %}active{% endif %}">
                Récents
            </a>
            <a href="{{ path('app_forum_index', {'sort': 'likes'}) }}" class="filter-tab {% if sortBy == 'likes' %}active{% endif %}">
                Populaires
            </a>
            <a href="{{ path('app_forum_index', {'sort': 'sujet'}) }}" class="filter-tab {% if sortBy == 'sujet' %}active{% endif %}">
                Discussions
            </a>
        </div>
        
        <div class="filter-search-wrap">
            <div class="filter-search">
                <i class="fas fa-search"></i>
                <input type="text" name="search" placeholder="Rechercher..." value="{{ search }}">
            </div>
            <select name="sort" class="filter-sort">
                <option value="dateCreation" {% if sortBy == 'dateCreation' %}selected{% endif %}>Plus récents</option>
                <option value="sujet" {% if sortBy == 'sujet' %}selected{% endif %}>Populaires</option>
                <option value="likes" {% if sortBy == 'likes' %}selected{% endif %}>Plus aimés</option>
            </select>
        </div>
        
        <a href="{{ path('app_forum_new') }}" class="filter-btn-submit">
            <i class="fas fa-plus"></i>
            Nouveau post
        </a>
    </div>

    <!-- Main Content -->
    <main class="forum-main">
        <!-- Posts Feed -->
        <div class="posts-feed">
            {% for forum in forums %}
                <article class="post-card" data-forum-id="{{ forum.id }}">
                    <!-- Post Header -->
                    <header class="post-header">
                        <div class="post-author">
                            <div class="author-avatar">
                                <div class="avatar-placeholder">
                                    <i class="fas fa-user"></i>
                                    <span>{{ forum.nom|first }}{{ forum.prenom|first }}</span>
                                </div>
                            </div>
                            <div class="author-info">
                                <div class="author-name">{{ forum.nom }} {{ forum.prenom }}</div>
                                <div class="author-meta">
                                    <span class="post-date">{{ forum.dateCreation ? forum.dateCreation|date('d M \à H:i') : '' }}</span>
                                    <span class="author-badge {% if loop.index0 == 0 %}featured{% endif %}">
                                        {% if loop.index0 == 0 %}🔥{% endif %} 
                                        {% if loop.index0 == 0 %}Populaire{% endif %}
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="post-actions">
                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="dropdown">
                                    <button class="action-btn" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-h"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a href="{{ path('app_forum_edit', {'id': forum.id}) }}" class="dropdown-item">
                                            <i class="fas fa-edit"></i> Modifier
                                        </a></li>
                                        <li>
                                            {{ include('forum/_delete_form.html.twig') }}
                                        </li>
                                    </ul>
                                </div>
                            {% endif %}
                        </div>
                    </header>

                    <!-- Post Content -->
                    <div class="post-content">
                        <h2 class="post-title">{{ forum.sujet }}</h2>
                        <div class="post-body">{{ forum.message|nl2br }}</div>
                    </div>

                    <!-- Post Footer -->
                    <footer class="post-footer">
                        <div class="post-stats">
                            <button class="stat-btn like-btn" 
                                    data-forum-id="{{ forum.id }}"
                                    data-liked="{{ app.user ? (forum.likes|filter(like => like.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                                <i class="far fa-heart"></i>
                                <span class="stat-count">{{ forum.getLikesCount() }}</span>
                            </button>
                            <a href="{{ path('app_forum_show', {'id': forum.id}) }}" class="stat-btn">
                                <i class="far fa-comment"></i>
                                <span class="stat-count">{{ forum.reponses|length }}</span>
                            </a>
                        </div>
                        
                        <div class="post-engagement">
                            <button class="engagement-btn report-btn" 
                                    data-forum-id="{{ forum.id }}"
                                    data-reported="{{ app.user ? (forum.signalements|filter(report => report.user == app.user)|length > 0 ? 'true' : 'false') : 'false' }}">
                                <i class="far fa-flag"></i>
                                <span>Signaler</span>
                            </button>
                            <button class="engagement-btn pdf-btn" onclick="saveForumPdf({{ forum.id }})">
                                <i class="fas fa-file-pdf"></i>
                                <span>Sauvegarder PDF</span>
                            </button>
                        </div>
                    </footer>
                </article>
            {% else %}
                <div class="fo-empty">
                    <i class="fas fa-comments"></i>
                    <h3>Aucune publication</h3>
                    <p>
                        Soyez le premier à partager vos pensées avec la communauté.
                    </p>
                    <a href="{{ path('app_forum_new') }}" class="filter-btn-submit">
                        <i class="fas fa-plus"></i>
                        Créer le premier post
                    </a>
                </div>
            {% endfor %}
        </div>
    </main>
</div>

<style>
/* ===== CSS VARIABLES ===== */
:root {
    --ac-deep: #1E0F75;
    --ac-mid: #3785D8;
    --ac-lavender: #BF8CE1;
    --ac-sky: #ADC6E5;
    --ac-pink: #EBB2C3;
    --text-primary: #1a1a1a;
    --text-secondary: #6b7280;
    --text-muted: #9ca3af;
    --bg-primary: #ffffff;
    --bg-secondary: #f8fafc;
    --bg-tertiary: #f1f5f9;
    --border-primary: #e2e8f0;
    --border-secondary: #f3f4f6;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
    --shadow-md: 0 4px 6px rgba(0,0,0,0.1), 0 2px 4px rgba(0,0,0,0.06);
    --shadow-lg: 0 10px 25px rgba(0,0,0,0.1), 0 6px 10px rgba(0,0,0,0.08);
    --shadow-xl: 0 20px 40px rgba(30,15,117,0.15);
    --radius-sm: 6px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --radius-2xl: 24px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ===== FORUM CONTAINER ===== */
.forum-container {
    min-height: 100vh;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    font-family: 'Sora', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    padding: 2rem;
    position: relative;
}

.forum-container::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 50%, var(--ac-lavender) 100%);
    opacity: 0.05;
    z-index: -1;
}

/* ===== HEADER ===== */
.fo-ev-header {
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    margin-bottom: 2rem; 
    padding: 1.5rem 2rem;
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
}

.fo-ev-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--ac-deep), var(--ac-mid), var(--ac-lavender));
}

.fo-ev-header h1 {
    margin: 0; 
    font-family: 'Sora', sans-serif;
    font-size: 2rem; 
    font-weight: 800; 
    color: var(--text-primary);
    display: flex; 
    align-items: center; 
    gap: 1rem;
    position: relative;
}

.fo-ev-header h1::before {
    content: '💬';
    font-size: 2.5rem;
    animation: bounce 2s infinite;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
}

.fo-ev-header .badge { 
    font-size: 0.875rem; 
    border-radius: var(--radius-lg); 
    background: linear-gradient(135deg, var(--ac-mid), var(--ac-lavender));
    color: white;
    padding: 0.5rem 1rem;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
}

/* ===== MAIN LAYOUT ===== */
.forum-main {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
}

/* ===== POSTS FEED ===== */
.posts-feed {
    flex: 1;
    min-width: 0;
}

/* ===== FILTER BAR ===== */
.filter-bar {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    margin-bottom: 2rem;
    display: flex; 
    align-items: center; 
    gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    backdrop-filter: blur(10px);
}

.filter-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.filter-tabs {
    display: flex; 
    gap: 0.5rem;
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    padding: 0.5rem;
    flex: 1;
}

.filter-tab {
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: transparent;
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
    text-decoration: none; 
    display: inline-flex; 
    align-items: center;
    position: relative;
    overflow: hidden;
}

.filter-tab::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    opacity: 0;
    transition: var(--transition);
}

.filter-tab:hover::before {
    opacity: 0.1;
}

.filter-tab.active {
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 55%, var(--ac-lavender) 100%); 
    color: #fff; 
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
}

.filter-tab.active::before {
    opacity: 0;
}

.filter-tab:not(.active):hover {
    background: rgba(30,15,117,0.1);
    color: var(--ac-deep);
    transform: translateY(-1px);
}
.filter-search-wrap {
    display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;
    flex: 1; min-width: 0;
}
.filter-search-wrap .filter-search { flex: 1; min-width: 160px; }
.filter-search-wrap .filter-sort { min-width: 140px; }
.filter-tab.filter-tab-all {
    cursor: default; pointer-events: none;
}
.filter-toggle-adv { position: relative; }
.filter-toggle-adv .filter-adv-dot {
    position: absolute; top: 6px; right: 6px;
    width: 6px; height: 6px; border-radius: 50%;
    background: #fff; opacity: 0.9; display: none;
}
.filter-toggle-adv.active .filter-adv-dot { display: block; }
.filter-adv-title {
    font-size: 0.8rem; font-weight: 700; color: #1E0F75;
    margin-bottom: 0.6rem; display: block;
}
.filter-adv-actions { min-width: auto; }
.visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}
.filter-search {
    position: relative;
    flex: 1;
    min-width: 200px;
}

.filter-search input {
    width: 100%; 
    border: 2px solid var(--border-primary);
    border-radius: var(--radius-lg); 
    padding: 0.75rem 1rem 0.75rem 3rem;
    font-size: 0.875rem; 
    background: var(--bg-tertiary);
    transition: var(--transition);
    color: var(--text-primary);
}

.filter-search input:focus {
    outline: none; 
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55,133,216,0.1);
    background: var(--bg-primary);
}

.filter-search input::placeholder {
    color: var(--text-muted);
}

.filter-search i {
    position: absolute; 
    left: 1rem; 
    top: 50%; 
    transform: translateY(-50%);
    color: var(--text-muted); 
    font-size: 0.875rem;
    transition: var(--transition);
}

.filter-search:focus-within i {
    color: var(--ac-mid);
}

.filter-sort {
    border: 2px solid var(--border-primary);
    border-radius: var(--radius-lg); 
    padding: 0.75rem 1rem;
    font-size: 0.875rem; 
    background: var(--bg-tertiary);
    cursor: pointer; 
    color: var(--text-secondary);
    transition: var(--transition);
    min-width: 140px;
}

.filter-sort:focus { 
    outline: none; 
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55,133,216,0.1);
    background: var(--bg-primary);
}

.filter-btn-submit {
    border-radius: var(--radius-lg); 
    font-weight: 700; 
    font-size: 0.875rem;
    padding: 0.75rem 1.5rem; 
    min-width: 120px; 
    border: none;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: #fff; 
    cursor: pointer; 
    transition: var(--transition);
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
}

.filter-btn-submit::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.filter-btn-submit:hover { 
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.filter-btn-submit:hover::before {
    left: 100%;
}

.filter-btn-submit:active {
    transform: translateY(0);
}
.filter-count {
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(30,15,117,0.08); color: #1E0F75;
    border-radius: 6px; font-size: 0.7rem; font-weight: 700;
    min-width: 20px; height: 18px; padding: 0 4px; margin-left: 4px;
}
.filter-tab.active .filter-count {
    background: rgba(255,255,255,0.25); color: #fff;
}
.filter-advanced {
    background: #fff;
    border-radius: 24px;
    padding: 0.8rem 1rem;
    box-shadow: 0 4px 16px rgba(30,15,117,0.06);
    border: 1px solid rgba(30,15,117,0.08);
    border-top: none;
    margin-top: -1.5rem; margin-bottom: 1.5rem;
    animation: slideDown 0.3s ease;
}
@keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
.filter-adv-row {
    display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: end;
}
.filter-adv-group { flex: 1; min-width: 140px; }
.filter-adv-group label {
    display: block; font-size: 0.72rem; font-weight: 700;
    color: #666; margin-bottom: 0.2rem;
}
.filter-adv-group input {
    width: 100%; border: 1px solid rgba(30,15,117,0.1);
    border-radius: 14px; padding: 0.5rem 0.75rem;
    font-size: 0.82rem; background: #faf9fe;
}
.filter-adv-group input:focus {
    outline: none; border-color: #3785D8;
    box-shadow: 0 0 0 2px rgba(55,133,216,0.1);
}
.filter-reset-btn {
    border: 1px solid rgba(220,53,69,0.3);
    background: rgba(220,53,69,0.05);
    color: #dc3545; border-radius: 14px;
    padding: 0.5rem 0.9rem; font-size: 0.78rem;
    font-weight: 600; cursor: pointer;
    transition: all 0.2s; white-space: nowrap;
    text-decoration: none; display: inline-block;
}
.filter-reset-btn:hover {
    background: #dc3545; color: #fff;
}

    /* ===== POST CARDS ===== */
.post-card {
    background: var(--bg-primary);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-primary);
    transition: var(--transition);
    margin-bottom: 2rem;
    position: relative;
    backdrop-filter: blur(10px);
}

.post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--ac-sky), var(--ac-mid), var(--ac-lavender));
    opacity: 0;
    transition: var(--transition);
}

.post-card:hover::before {
    opacity: 1;
}

.post-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--ac-mid);
}

.post-card-author-badge {
    position: absolute; 
    top: 1rem; 
    right: 1rem; 
    z-index: 2;
    font-size: 0.75rem; 
    font-weight: 700; 
    padding: 0.5rem 1rem;
    border-radius: var(--radius-lg); 
    backdrop-filter: blur(10px);
    display: flex; 
    align-items: center; 
    gap: 0.5rem;
    box-shadow: var(--shadow-sm);
}

.post-card-author-badge.mine-badge {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: #fff;
}

.post-card-author-badge.op-badge {
    background: linear-gradient(135deg, var(--ac-mid), var(--ac-lavender));
    color: #fff;
}

@keyframes fadeInUp { 
    from { opacity: 0; transform: translateY(20px); } 
    to { opacity: 1; transform: translateY(0); } 
}

.post-card { 
    animation: fadeInUp 0.6s ease both;
}

.post-card:nth-child(1) { animation-delay: 0.1s; }
.post-card:nth-child(2) { animation-delay: 0.2s; }
.post-card:nth-child(3) { animation-delay: 0.3s; }
.post-card:nth-child(4) { animation-delay: 0.4s; }
.post-card:nth-child(5) { animation-delay: 0.5s; }

/* ===== POST COMPONENTS ===== */
.post-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-secondary);
    position: relative;
}

.post-author {
    display: flex;
    align-items: center;
    gap: 1.25rem;
}

.author-avatar {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.avatar-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--ac-deep), var(--ac-lavender));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 1.25rem;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
}

.avatar-placeholder::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
    animation: shine 3s infinite;
}

@keyframes shine {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.author-info {
    flex: 1;
}

.author-name {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
}

.author-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.post-date {
    color: var(--text-muted);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.post-date::before {
    content: '📅';
    font-size: 0.75rem;
}

.author-badge {
    background: linear-gradient(135deg, var(--ac-pink), var(--ac-lavender));
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-xl);
    font-size: 0.75rem;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
}

.author-badge.featured {
    background: linear-gradient(135deg, var(--ac-mid), var(--ac-deep));
    color: white;
}

.author-badge.featured::before {
    content: '🔥 ';
    margin-right: 0.25rem;
}

.post-actions {
    position: relative;
}

.action-btn {
    background: transparent;
    border: 1px solid var(--border-primary);
    padding: 0.5rem;
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.action-btn:hover {
    background: var(--bg-tertiary);
    color: var(--ac-mid);
    border-color: var(--ac-mid);
    transform: scale(1.1);
}

.post-content {
    padding: 0 2rem 1.5rem;
}

.post-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    line-height: 1.3;
    position: relative;
    padding-left: 1rem;
}

.post-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 70%;
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    border-radius: var(--radius-sm);
}

.post-body {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 1rem;
    margin-bottom: 1rem;
    position: relative;
    padding-left: 1rem;
}

.post-body::before {
    content: '"';
    position: absolute;
    left: -0.5rem;
    top: 0;
    font-size: 3rem;
    color: var(--ac-mid);
    opacity: 0.2;
    font-family: Georgia, serif;
}

.post-footer {
    padding: 1.5rem 2rem;
    background: var(--bg-tertiary);
    border-top: 1px solid var(--border-secondary);
    position: relative;
}

