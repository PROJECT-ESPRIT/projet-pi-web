            if (responsesContainer) {
                const isVisible = responsesContainer.style.display !== 'none';
                console.log('État actuel:', isVisible);
                responsesContainer.style.display = isVisible ? 'none' : 'block';
                console.log('Nouvel état:', responsesContainer.style.display);
                
                // Si on affiche la section, scroller jusqu'au formulaire et donner le focus
                if (!isVisible) {
