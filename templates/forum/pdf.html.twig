<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ forum.sujet }} - Forum Post PDF</title>
    <style>
        @page {
            margin: 2cm;
            size: A4;
            @bottom-center {
                content: "Generated on {{ generationDate|date('F j, Y, g:i a') }}";
                font-size: 10px;
                color: #666;
                border-top: 1px solid #ccc;
                padding-top: 5px;
            }
        }
        
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
        }
        
        .header {
            text-align: center;
            border-bottom: 2px solid #007bff;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        
        .header h1 {
            color: #007bff;
            font-size: 24px;
            margin: 0;
        }
        
        .header .forum-name {
            font-size: 14px;
            color: #666;
            margin-top: 5px;
        }
        
        .post-title {
            font-size: 18px;
            font-weight: bold;
            color: #333;
            margin-bottom: 15px;
            border-left: 4px solid #007bff;
            padding-left: 15px;
        }
        
        .post-meta {
            background-color: #f8f9fa;
            padding: 10px 15px;
            border-radius: 5px;
            margin-bottom: 20px;
            font-size: 11px;
        }
        
        .post-meta .author {
            font-weight: bold;
            color: #007bff;
        }
        
        .post-content {
            margin-bottom: 30px;
            text-align: justify;
            white-space: pre-wrap;
        }
        
        .comments-section {
            margin-top: 40px;
        }
        
        .comments-header {
            font-size: 16px;
            font-weight: bold;
            color: #333;
            border-bottom: 1px solid #ddd;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
        
        .comment {
            background-color: #f8f9fa;
            border-left: 3px solid #28a745;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 0 5px 5px 0;
        }
        
        .comment-meta {
            font-size: 10px;
            color: #666;
            margin-bottom: 8px;
            border-bottom: 1px solid #e9ecef;
            padding-bottom: 5px;
        }
        
        .comment-meta .author {
            font-weight: bold;
            color: #28a745;
        }
        
        .comment-content {
            text-align: justify;
            white-space: pre-wrap;
        }
        
        .no-comments {
            text-align: center;
            color: #666;
            font-style: italic;
            padding: 20px;
            background-color: #f8f9fa;
            border-radius: 5px;
        }
        
        .footer {
            position: absolute;
            bottom: -20px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 10px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Community Forum</h1>
        <div class="forum-name">Discussion Platform</div>
    </div>

    <div class="post-title">
        {{ forum.sujet }}
    </div>

    <div class="post-meta">
        <div>
            <span class="author">Author: {{ forum.prenom }} {{ forum.nom }}</span> | 
            <span>Email: {{ forum.email }}</span> | 
            <span>Posted: {{ forum.dateCreation|date('F j, Y, g:i a') }}</span>
        </div>
    </div>

    <div class="post-content">
        {{ forum.message }}
    </div>

    <div class="comments-section">
        <div class="comments-header">
            Comments ({{ forum.reponses|length }})
        </div>

        {% if forum.reponses|length > 0 %}
            {% for reponse in forum.reponses %}
                <div class="comment">
                    <div class="comment-meta">
                        <span class="author">{{ reponse.auteur.prenom }} {{ reponse.auteur.nom }}</span> | 
                        <span>{{ reponse.dateReponse|date('F j, Y, g:i a') }}</span>
                    </div>
                    <div class="comment-content">
                        {{ reponse.contenu }}
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="no-comments">
                No comments yet for this post.
            </div>
        {% endif %}
    </div>
</body>
</html>
