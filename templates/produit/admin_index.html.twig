{% extends 'base.html.twig' %}

{% block title %}Gestion des Produits{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1 class="mb-4">Gestion des Produits (Analyse IA)</h1>

    <div class="mb-3 text-end">
        <a href="{{ path('app_produit_new') }}" class="btn btn-success">
            Ajouter un produit
        </a>
    </div>

    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prix</th>
                <th>Stock</th>
                <th>Prévision (mois prochain)</th>
                <th>Risque Rupture</th>
                <th>Graphique</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for produit in produits %}
            <tr>
                <td>{{ produit.id }}</td>
                <td>{{ produit.nom }}</td>
                <td>{{ produit.prix }} TND</td>
                <td>
                    {{ produit.stock }}

                    {% if predictions[produit.id].rupture %}
                        <span class="badge bg-danger ms-2">⚠ Stock insuffisant</span>
                    {% endif %}
                </td>

                <td class="fw-bold text-primary">
                    {{ predictions[produit.id].prediction }}
                </td>

                <td>
                    {% if predictions[produit.id].rupture %}
                        <span class="badge bg-danger">Risque élevé</span>
                    {% else %}
                        <span class="badge bg-success">Stable</span>
                    {% endif %}
                </td>

                <td>
                    <canvas id="chart{{ produit.id }}" width="180" height="90"></canvas>
                </td>

                <td>
                    <a href="{{ path('app_produit_edit', {'id': produit.id}) }}" 
                       class="btn btn-sm btn-warning">
                        Éditer
                    </a>

                    {{ include('produit/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" class="text-center">
                    Aucun produit trouvé
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
{% for produit in produits %}
    new Chart(
        document.getElementById('chart{{ produit.id }}'),
        {
            type: 'line',
            data: {
                labels: ['M-3','M-2','M-1','M'],
                datasets: [{
                    label: 'Ventes',
                    data: {{ predictions[produit.id].historique|json_encode|raw }},
                    borderColor: 'blue',
                    backgroundColor: 'rgba(0, 123, 255, 0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        }
    );
{% endfor %}
</script>
{% endblock %}
