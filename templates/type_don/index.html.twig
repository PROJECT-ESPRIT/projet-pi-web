{% extends 'base.html.twig' %}

{% block title %}Types de Don{% endblock %}

{% block body %}
    <div class="bo-page-header">
        <h1>
            <i class="fas fa-tags"></i> Types de don
            <span class="badge">{{ type_dons|length }}</span>
        </h1>
        <div class="bo-actions">
            <a href="{{ path('app_type_don_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Nouveau type</a>
        </div>
    </div>

    <form method="get" action="{{ path('app_type_don_index') }}" class="bo-filter-bar">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-5">
                <label><i class="fas fa-search me-1"></i>Recherche</label>
                <input type="text" name="q" class="form-control" placeholder="Rechercher un libelle..." value="{{ search|default('') }}">
            </div>
            <div class="col-6 col-md-3">
                <label><i class="fas fa-sort me-1"></i>Trier par</label>
                <select name="sort" class="form-select">
                    <option value="id" {{ (sort|default('id')) == 'id' ? 'selected' : '' }}>ID</option>
                    <option value="libelle" {{ (sort|default('id')) == 'libelle' ? 'selected' : '' }}>Libelle</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label><i class="fas fa-arrows-alt-v me-1"></i>Ordre</label>
                <select name="direction" class="form-select">
                    <option value="asc" {{ (direction|default('asc')) == 'asc' ? 'selected' : '' }}>Asc</option>
                    <option value="desc" {{ (direction|default('asc')) == 'desc' ? 'selected' : '' }}>Desc</option>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1"><i class="fas fa-filter me-1"></i>Filtrer</button>
                <a href="{{ path('app_type_don_index') }}" class="btn btn-outline-secondary"><i class="fas fa-undo"></i></a>
            </div>
        </div>
    </form>

    <div class="bo-table-card">
        <div class="table-responsive">
            <table class="table bo-table align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Libelle</th>
                        <th>Image</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for type_don in type_dons %}
                    <tr>
                        <td>#{{ type_don.id }}</td>
                        <td>{{ type_don.libelle }}</td>
                        <td>
                            {% if type_don.picturePath %}
                                <img src="{{ type_don.picturePath }}" alt="{{ type_don.libelle }}" style="max-height:32px">
                            {% else %}
                                <span class="text-muted small">—</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_type_don_edit', {'id': type_don.id}) }}" class="btn btn-outline-primary" title="Editer"><i class="fas fa-edit"></i></a>
                                {{ include('type_don/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted">Aucun type trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
