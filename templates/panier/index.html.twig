{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}
<h1>Mon Panier</h1>

{% if cart is empty %}
    <p>Votre panier est vide.</p>
{% else %}
    <table class="table">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix Unitaire</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for item in cart %}
            <tr>
                <td>{{ item.produit.nom }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.produit.prix }} €</td>
                <td>{{ item.produit.prix * item.quantity }} €</td>
                <td>
                    <a href="{{ path('app_panier_remove', {'id': item.produit.id}) }}" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <h3>Total : {{ total }} €</h3>
    <a href="{{ path('app_panier_clear') }}" class="btn btn-warning">Vider le panier</a>
{% endif %}
{% endblock %}