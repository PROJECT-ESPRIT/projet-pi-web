{% extends 'base.html.twig' %}

{% block title %}Créer une cause{% endblock %}

{% block body %}
    <div class="bo-page-header">
        <h1><i class="fas fa-plus-circle"></i> Nouvelle cause</h1>
        <div class="bo-actions">
            <a href="{{ path('app_charity_mine') }}" class="btn btn-outline-secondary"><i class="fas fa-folder me-1"></i>Mes causes</a>
            <a href="{{ path('app_charity_index') }}" class="btn btn-outline-secondary"><i class="fas fa-list me-1"></i>Toutes</a>
        </div>
    </div>

    <div class="bo-table-card p-3">
        {{ include('charity/_form.html.twig', {'form': form, 'button_label': 'Créer'}) }}
        <small class="text-muted d-block mt-2">Formats conseillés: JPG/PNG. L'image sera affichée sur la liste des causes.</small>
    </div>
{% endblock %}
