{% extends 'base.html.twig' %}

{% block title %}Mes causes{% endblock %}

{% block body %}
    <style>
        .charity-grid .charity-card { border: 1px solid #e9ecef; border-radius: 14px; box-shadow: 0 8px 24px rgba(0,0,0,.06); }
        .charity-grid .charity-card .progress { height: 11px; border-radius: 999px; }
        .charity-grid .meta-pill { font-size: .74rem; border-radius: 999px; padding: .25rem .65rem; }
        .charity-grid .percent { font-weight: 700; font-size: .88rem; }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Mes causes</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_charity_new') }}" class="btn btn-primary">Créer une cause</a>
            <a href="{{ path('app_charity_index') }}" class="btn btn-outline-secondary">Voir toutes les causes</a>
        </div>
    </div>

    <p class="text-muted mb-4">
        Gérez vos causes et suivez leur progression.
    </p>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-6">
            <label for="charity-search" class="form-label">Recherche</label>
            <input
                type="text"
                id="charity-search"
                name="q"
                class="form-control"
                placeholder="Nom ou description..."
                value="{{ search }}"
            >
        </div>
        <div class="col-md-3">
            <label for="charity-sort" class="form-label">Trier par</label>
            <select id="charity-sort" name="sort" class="form-select">
                <option value="name" {{ sort == 'name' ? 'selected' : '' }}>Nom</option>
                <option value="newest" {{ sort == 'newest' ? 'selected' : '' }}>Nouveauté</option>
                <option value="donations" {{ sort == 'donations' ? 'selected' : '' }}>Nombre de dons</option>
                <option value="amount" {{ sort == 'amount' ? 'selected' : '' }}>Montant collecté</option>
                <option value="goal" {{ sort == 'goal' ? 'selected' : '' }}>Objectif</option>
                <option value="progress" {{ sort == 'progress' ? 'selected' : '' }}>Progression</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="charity-direction" class="form-label">Ordre</label>
            <select id="charity-direction" name="direction" class="form-select">
                <option value="ASC" {{ direction == 'ASC' ? 'selected' : '' }}>Croissant</option>
                <option value="DESC" {{ direction == 'DESC' ? 'selected' : '' }}>Décroissant</option>
            </select>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Appliquer</button>
            <a href="{{ path('app_charity_mine') }}" class="btn btn-outline-secondary">Réinitialiser</a>
        </div>
    </form>

    <div class="row g-4 charity-grid">
        {% for row in charityStats %}
            {% set charity = row.charity %}
            {% set percent = row.progressPercent %}
            {% set barClass = percent >= 100 ? 'bg-success' : (row.hasGoal ? 'bg-danger' : 'bg-secondary') %}
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 charity-card">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                            <h5 class="card-title mb-0">{{ charity.name }}</h5>
                            <span class="badge text-bg-light meta-pill">{{ row.donationsCount }} dons</span>
                        </div>

                        {% if charity.imagePath %}
                            <img src="{{ charity.imagePath }}" alt="{{ charity.name }}" class="w-100 rounded mb-2" style="height: 140px; object-fit: cover;">
                        {% endif %}

                        <p class="card-text text-muted mb-3">
                            {{ charity.description ?: 'Aucune description disponible.' }}
                        </p>

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="text-muted">
                                    {% if row.hasGoal %}
                                        Objectif: {{ charity.goalAmount }} €
                                    {% else %}
                                        Objectif: non défini
                                    {% endif %}
                                </small>
                                <span class="percent {{ percent >= 100 ? 'text-success' : (row.hasGoal ? 'text-danger' : 'text-muted') }}">
                                    {{ row.hasGoal ? percent ~ '%' : '—' }}
                                </span>
                            </div>
                            <div class="progress mb-2">
                                <div class="progress-bar {{ barClass }}" role="progressbar" style="width: {{ min(percent, 100) }}%"></div>
                            </div>
                            <small class="text-muted d-block mb-3">{{ row.donationsAmount }} € collectés · {{ row.donationsCount }} dons</small>

                            <div class="d-flex gap-2">
                                <a href="{{ path('app_charity_show', {'id': charity.id}) }}" class="btn btn-outline-secondary btn-sm">Voir</a>
                                <a href="{{ path('app_charity_edit', {'id': charity.id}) }}" class="btn btn-outline-primary btn-sm">Modifier</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info mb-0">Vous n'avez pas encore créé de cause.</div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
