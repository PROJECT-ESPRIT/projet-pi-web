{% extends 'base.html.twig' %}

{% block title %}Modifier une cause{% endblock %}

{% block body %}
    <div class="bo-page-header">
        <h1><i class="fas fa-edit"></i> Modifier — {{ charity.name }}</h1>
        <div class="bo-actions">
            <a href="{{ path('app_charity_show', {id: charity.id}) }}" class="btn btn-outline-secondary"><i class="fas fa-eye me-1"></i>Voir</a>
            <a href="{{ path('app_charity_mine') }}" class="btn btn-outline-secondary"><i class="fas fa-folder me-1"></i>Mes causes</a>
        </div>
    </div>

    <div class="bo-table-card p-3 mb-3">
        {{ include('charity/_form.html.twig', {'form': form, 'button_label': 'Enregistrer'}) }}
        {% if charity.imagePath %}
            <div class="mt-3">
                <div class="small text-muted mb-2">Image actuelle</div>
                <img src="{{ charity.imagePath }}" alt="{{ charity.name }}" style="max-width: 320px; border-radius: 10px;">
            </div>
        {% endif %}
    </div>

    <form method="post" action="{{ path('app_charity_delete', {'id': charity.id}) }}" onsubmit="return confirm('Supprimer cette cause ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete-charity-' ~ charity.id) }}">
        <button class="btn btn-outline-danger"><i class="fas fa-trash me-1"></i>Supprimer cette cause</button>
    </form>
{% endblock %}
