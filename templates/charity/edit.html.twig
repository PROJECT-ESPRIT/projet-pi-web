{% extends 'base.html.twig' %}

{% block title %}Modifier une cause{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Modifier une cause</h1>
        <a href="{{ path('app_charity_mine') }}" class="btn btn-outline-secondary">Mes causes</a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            {{ include('charity/_form.html.twig', {'form': form, 'button_label': 'Enregistrer'}) }}
            {% if charity.imagePath %}
                <div class="mt-3">
                    <div class="small text-muted mb-2">Image actuelle</div>
                    <img src="{{ charity.imagePath }}" alt="{{ charity.name }}" style="max-width: 320px; border-radius: 10px;">
                </div>
            {% endif %}
        </div>
    </div>

    <form method="post" action="{{ path('app_charity_delete', {'id': charity.id}) }}" onsubmit="return confirm('Supprimer cette cause ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete-charity-' ~ charity.id) }}">
        <button class="btn btn-outline-danger">Supprimer</button>
    </form>
{% endblock %}
