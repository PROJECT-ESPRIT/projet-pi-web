{% extends 'base.html.twig' %}

{% block title %}Faire un Don{% endblock %}

{% block body %}
    <h1>Faire un Don</h1>

    {% if charity is defined %}
        <div class="alert alert-secondary">
            <strong>Charity sélectionnée :</strong> {{ charity.name }}
        </div>
    {% endif %}

    <p class="lead">Merci de votre générosité. Indiquez le montant en € et cochez l'option de don anonyme si besoin.</p>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        {{ form_widget(form) }}
        <button class="btn btn-success mt-3">Confirmer le don</button>
    {{ form_end(form) }}

    <div class="mt-3 d-flex gap-3">
        {% if charity is defined %}
            <a href="{{ path('app_charity_show', {'id': charity.id}) }}">Retour à la charity</a>
        {% else %}
            <a href="{{ path('app_charity_index') }}">Voir les charities</a>
        {% endif %}
        <a href="{{ path('app_donation_my') }}">Voir mes dons</a>
    </div>
{% endblock %}
