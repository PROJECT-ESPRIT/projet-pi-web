{% extends 'base.html.twig' %}

{% block title %}Mes dons{% endblock %}

{% block body %}
    <div class="bo-page-header">
        <h1>
            <i class="fas fa-receipt"></i> Mes dons
            <span class="badge">{{ donations|length }}</span>
        </h1>
        <div class="bo-actions">
            <a href="{{ path('app_charity_index') }}" class="btn btn-primary"><i class="fas fa-hand-holding-heart me-1"></i>Faire un don</a>
        </div>
    </div>

    {% if donations is empty %}
        <div class="alert alert-info">
            Vous n'avez pas encore fait de don. <a href="{{ path('app_charity_index') }}">Découvrir les causes</a>.
        </div>
    {% else %}
        <div class="row g-3">
            {% for donation in donations %}
                {% set st = donation.status %}
                {% set badgeClass = st == 'APPROVED' ? 'bg-success'
                    : (st == 'REJECTED' ? 'bg-danger'
                    : (st == 'HIDDEN' ? 'bg-secondary' : 'bg-warning text-dark')) %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>
                                <span class="badge bg-info">{{ donation.donationType }}</span>
                                {% if donation.type %}<small class="ms-1">{{ donation.type.libelle }}</small>{% endif %}
                            </span>
                            <span class="badge {{ badgeClass }}">{{ st }}</span>
                        </div>
                        <div class="card-body">
                            <h6 class="card-title">{{ donation.charity ? donation.charity.name : 'Cause supprimée' }}</h6>
                            <div class="small text-muted mb-2">{{ donation.dateDon|date('d/m/Y H:i') }}</div>
                            <p class="mb-2"><strong>Montant:</strong> {{ donation.amount }} €</p>
                            {% if donation.isAnonymous %}
                                <span class="badge text-bg-secondary mb-2">Don anonyme</span>
                            {% endif %}
                            {% if donation.description %}
                                <p class="card-text small text-muted">{{ donation.description }}</p>
                            {% endif %}
                            {% if donation.imagePath %}
                                <img src="{{ donation.imagePath }}" class="img-fluid rounded" style="max-height:120px" alt="don">
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
