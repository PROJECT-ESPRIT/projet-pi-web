{% set entity = reponse is defined ? reponse : forum_reponse %}
<form method="post" action="{{ path('app_forum_reponse_delete', {'id': entity.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette réponse ?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entity.id) }}">
    <button type="submit" class="dropdown-item text-danger">
        <i class="fas fa-trash me-1"></i> Supprimer
    </button>
</form>
