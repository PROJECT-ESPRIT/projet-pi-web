{% extends 'base.html.twig' %}

{% block title %}Modifier la réponse - Forum{% endblock %}

{% block body %}
<style>
:root {
    --ac-deep: #1E0F75;
    --ac-mid: #3785D8;
    --ac-lavender: #BF8CE1;
    --text-primary: #1a1a1a;
    --text-secondary: #6b7280;
    --bg-primary: #ffffff;
    --bg-secondary: #f8fafc;
    --border-primary: #e2e8f0;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
    --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
    --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --transition: all 0.3s ease;
}

/* ===== PAGE CONTAINER ===== */
.edit-container {
    min-height: 100vh;
    background: linear-gradient(135deg, var(--bg-secondary) 0%, #f1f5f9 100%);
    padding: 2rem;
    position: relative;
}

.edit-container::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, var(--ac-deep) 0%, var(--ac-mid) 50%, var(--ac-lavender) 100%);
    opacity: 0.05;
    z-index: -1;
}

/* ===== MAIN CARD ===== */
.edit-card {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border-primary);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    backdrop-filter: blur(10px);
}

.edit-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--ac-mid), var(--ac-lavender));
    opacity: 0.8;
}

/* ===== HEADER ===== */
.edit-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-primary);
    position: relative;
}

.edit-header h1 {
    color: var(--text-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.edit-header h1::before {
    content: '✏️';
    font-size: 1.5rem;
}

/* ===== FORM ===== */
.edit-form {
    padding: 2rem;
}

.edit-form .form-group {
    margin-bottom: 1.5rem;
}

.edit-form label {
    display: block;
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
}

.edit-form textarea,
.edit-form input,
.edit-form select {
    width: 100%;
    border: 2px solid var(--border-primary);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-size: 1rem;
    background: var(--bg-secondary);
    color: var(--text-primary);
    transition: var(--transition);
    resize: vertical;
}

.edit-form textarea:focus,
.edit-form input:focus,
.edit-form select:focus {
    outline: none;
    border-color: var(--ac-mid);
    box-shadow: 0 0 0 3px rgba(55,133,216,0.1);
    background: var(--bg-primary);
}

.edit-form textarea {
    min-height: 120px;
    line-height: 1.5;
}

.edit-form .invalid-feedback {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    display: block;
}

.edit-form .is-invalid {
    border-color: #ef4444;
}

/* ===== BUTTONS ===== */
.edit-actions {
    padding: 0 2rem 2rem;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
}

.btn-primary {
    background: linear-gradient(135deg, var(--ac-deep), var(--ac-mid));
    color: white;
    border: none;
    padding: 0.75rem 2rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
}

.btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.btn-primary:hover::before {
    left: 100%;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-secondary {
    background: var(--bg-primary);
    color: var(--text-secondary);
    border: 2px solid var(--border-primary);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-secondary:hover {
    background: var(--bg-secondary);
    color: var(--ac-deep);
    border-color: var(--ac-mid);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.btn-danger {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: var(--shadow-md);
}

.btn-danger:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
}

/* ===== NAVIGATION ===== */
.edit-navigation {
    padding: 1rem 2rem;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
    display: flex;
    justify-content: center;
}

.edit-navigation .btn-secondary {
    background: var(--bg-primary);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
    .edit-container {
        padding: 1rem;
    }
    
    .edit-card {
        margin: 0;
        border-radius: var(--radius-lg);
    }
    
    .edit-header,
    .edit-form,
    .edit-actions {
        padding: 1.5rem;
    }
    
    .edit-header h1 {
        font-size: 1.5rem;
    }
    
    .edit-actions {
        flex-direction: column;
        gap: 1rem;
    }
    
    .btn-primary,
    .btn-secondary,
    .btn-danger {
        width: 100%;
        justify-content: center;
    }
}
</style>

<div class="edit-container">
    <div class="edit-card">
        <div class="edit-header">
            <h1>Modifier la réponse</h1>
        </div>
        
        <div class="edit-form">
            {{ include('forum_reponse/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
        
        <div class="edit-actions">
            <a href="{{ path('app_forum_show', {'id': forum_reponse.forum.id}) }}" class="btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour au sujet
            </a>
            
            {{ include('forum_reponse/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
